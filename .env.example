# ========================
# General config & Maintenance
# ========================

# Application ID
CRAFT_APP_ID=CraftCMS--4f5282d1-e140-4731-ba90-10259296d495

# Environment
CRAFT_ENVIRONMENT="dev"

# Adjust these per environment
CRAFT_DEV_MODE=1
CRAFT_ALLOW_ADMIN_CHANGES=1
CRAFT_DISALLOW_ROBOTS=1

# The secure key Craft will use for hashing and encrypting data
# This must match the key on the production server
CRAFT_SECURITY_KEY=TNdeqnKEKRmUujBKmNSb4FbKZaINZ6c_

# ========================
# Database
# ========================

# The database driver that will used ('mysql' or 'pgsql')
CRAFT_DB_DRIVER="mysql"
# The database server name or IP address (usually this is 'localhost' or '127.0.0.1')
CRAFT_DB_SERVER="db"
# The database username to connect with
CRAFT_DB_USER="db"
# The database password to connect with
CRAFT_DB_PASSWORD="db"
# The name of the database to select
CRAFT_DB_DATABASE="db"
# The database schema that will be used (PostgreSQL only)
CRAFT_DB_SCHEMA="public"
# The prefix that should be added to generated table names (only necessary if multiple things are sharing the same database)
CRAFT_DB_TABLE_PREFIX=""
# The port to connect to the database with. Will default to 5432 for PostgreSQL and 3306 for MySQL.
CRAFT_DB_PORT="3306"

# Site
CRAFT_DEFAULT_SITE_NAME="Halcyon Luxury Journeys"
CRAFT_DEFAULT_SITE_URL="https://halcyon.test"

# Folders
CRAFT_PUBLIC_FOLDER="web"

# ========================
# Assets
# ========================
ASSETS_BASE_PATH="/assets/volumes/"
# Base url for assets, used by Volumes, Asset Rev, and Imager (with trailing slash)
ASSETS_BASE_URL="/" # Assets are stored locally
# ASSETS_BASE_URL="https://BUCKETNAME.s3.amazonaws.com/" # Assets are served from S3
# ASSETS_BASE_URL="https://xxxxxxxxxxx.cloudfront.net/" # Assets served from CloudFront CDN
# ASSETS_BASE_URL="https://cdn.PROJECTDOMAIN.com.au/" #Assets are served from custom CDN

# Folder path for storing secure assets, if local
SECURE_ASSETS_FOLDER="secure-assets"

# -----------------------------------------------
# S3 Bucket configs (if assets, etc are stored on AWS)

# S3 Access Key ID
#ASSETS_S3_ACCESS_KEY_ID=""
# S3 Access Key Secret
#ASSETS_S3_SECRET_ACCESS_KEY=""
# S3 Bucket Name
#ASSETS_S3_BUCKET="aurora-prod-assets"
# S3 Region Name
#ASSETS_S3_REGION="ap-southeast-2"
