# ========================
# Email delivery
# ========================

CRAFT_SYSTEM_EMAIL="web@simple.com.au"
#CRAFT_TEST_TO_EMAIL_ADDRESS="web@simple.com.au"

# ========================
# Mailjun
# ========================

# https://github.com/craftcms/mailgun/issues/26#issuecomment-1283895268
MAILGUN_DOMAIN=""
MAILGUN_API_KEY=""
MAILGUN_ENDPOINT=""
MAILHOG_SMTP_PORT="1025"
MAILHOG_SMTP_HOSTNAME="127.0.0.1"

# ========================
# MJML
# ========================

NODE_PATH="/usr/bin/node"
MJML_PATH="/usr/bin/mjml"

# ========================
# Knock Knock Password
# ========================

KNOCK_KNOCK_PASSWORD=letmein

