---
const destinations = [
  {
    name: 'The Whitsundays',
    region: 'Queensland',
    tagline: 'Sailing the jewels of the Coral Sea',
    image: 'https://picsum.photos/seed/whitsundays-au/900/1200',
    duration: '4–6 days',
    slug: '/destinations/whitsundays',
  },
  {
    name: 'Uluru',
    region: 'Northern Territory',
    tagline: 'Sacred land, infinite horizons',
    image: 'https://picsum.photos/seed/uluru-au/900/1200',
    duration: '2–4 days',
    slug: '/destinations/uluru',
  },
  {
    name: 'The Kimberley',
    region: 'Western Australia',
    tagline: "One of Earth's last true wildernesses",
    image: 'https://picsum.photos/seed/kimberley-au/900/1200',
    duration: '7–14 days',
    slug: '/destinations/kimberley',
  },
];
---

<section class="section-pad" style="background:#FFF1DA; position:relative; overflow:hidden;">

  <!-- Decorative Australia map SVG -->
  <svg
    viewBox="0 0 400 340"
    xmlns="http://www.w3.org/2000/svg"
    style="
      position:absolute;
      left:-5%;
      top:50%;
      transform:translateY(-50%);
      width:min(520px,50vw);
      opacity:0.055;
      fill:none;
      stroke:#112250;
      stroke-width:1.5;
      pointer-events:none;
    "
    aria-hidden="true"
  >
    <!-- Australia outline (simplified artistic path) -->
    <path d="
      M 245,18 C 265,18 288,24 304,36 C 320,48 330,65 336,80
      C 344,100 345,115 342,130 C 340,142 338,150 338,158
      C 340,165 348,172 350,182 C 353,196 344,212 335,224
      C 324,238 308,246 292,252 C 276,258 256,260 240,262
      C 222,264 202,264 186,260 C 168,256 154,245 142,238
      C 130,232 118,228 108,228 C 94,228 82,234 70,234
      C 56,234 44,226 36,215 C 26,202 22,186 24,170
      C 26,152 34,136 44,122 C 54,108 66,98 72,84
      C 78,70 78,55 86,44 C 96,30 114,22 134,18
      C 154,14 178,14 200,14 C 218,14 234,16 245,18 Z
    " />
    <!-- Cape York peninsula -->
    <path d="M 310,18 C 315,10 322,5 328,8 C 332,12 330,22 326,32 C 322,42 314,48 308,46 C 306,38 308,26 310,18 Z" />
    <!-- Gulf of Carpentaria indentation -->
    <path d="M 256,38 C 266,40 278,44 282,54 C 278,64 268,70 256,68 C 246,64 240,54 244,44 Z" fill="#FFF1DA" stroke="#112250" stroke-width="1"/>
    <!-- Tasmania -->
    <ellipse cx="292" cy="285" rx="20" ry="15" />
  </svg>

  <div class="container-xl">

    <!-- Section header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-16">
      <div>
        <div class="overline mb-4" data-reveal>beyond new zealand</div>
        <h2
          class="display text-navy"
          style="font-size:clamp(48px,6vw,88px); line-height:1;"
          data-reveal
          data-delay="100"
        >
          Australia
        </h2>
      </div>
      <a
        href="/destinations/australia"
        class="btn-luxury"
        style="white-space:nowrap; padding-bottom:4px;"
        data-reveal="right"
        data-delay="200"
      >
        All destinations
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
          <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
        </svg>
      </a>
    </div>

    <!-- Cards — wider, more spacious for Australia -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {destinations.map(({ name, region, tagline, image, duration, slug }, i) => (
        <a
          href={slug}
          class="dest-card group"
          data-reveal
          data-delay={String(i * 120)}
          style="text-decoration:none;"
        >
          <div style="overflow:hidden; aspect-ratio:4/5;">
            <img
              src={image}
              alt={name}
              class="dest-card-img"
              loading="lazy"
              decoding="async"
              width="600"
              height="750"
            />
          </div>

          <div
            class="type-body-font"
            style="
              position:absolute;
              top:16px; left:16px;
              font-size:9px;
              font-style:italic;
              letter-spacing:0.2em;
              color:#F5F0E9;
              background:rgba(17,34,80,0.65);
              backdrop-filter:blur(8px);
              padding:6px 12px;
            "
          >
            {duration}
          </div>

          <div class="dest-card-body">
            <div
              class="type-body-font"
              style="font-size:10px; font-style:italic; letter-spacing:0.2em; color:rgba(17,34,80,0.45); margin-bottom:8px;"
            >
              {region}
            </div>
            <div
              class="text-navy type-heading-font"
              style="font-size:clamp(20px,2vw,28px); font-weight:400; letter-spacing:0.06em; margin-bottom:8px;"
            >
              {name}
            </div>
            <div
              class="type-body-font"
              style="font-size:13px; font-style:italic; color:rgba(17,34,80,0.55); line-height:1.6; margin-bottom:16px;"
            >
              {tagline}
            </div>
            <span class="btn-luxury" style="font-size:11px;">
              Explore
              <svg width="12" height="8" viewBox="0 0 14 10" fill="none">
                <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
