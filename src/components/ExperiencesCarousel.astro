---
const experiences = [
  {
    title: 'Private Villa Estates',
    tagline: 'Your sanctuary, entirely your own',
    image: 'https://images.unsplash.com/photo-1613490493576-7fde63acd811?auto=format&fit=crop&w=900&q=90',
  },
  {
    title: 'Superyacht Charters',
    tagline: 'The open sea, on your terms',
    image: 'https://images.unsplash.com/photo-1605281317010-fe5ffe798166?auto=format&fit=crop&w=900&q=90',
  },
  {
    title: 'Helicopter Escapes',
    tagline: 'Land where others only dream of',
    image: 'https://images.unsplash.com/photo-1534430480872-3498386e7856?auto=format&fit=crop&w=900&q=90',
  },
  {
    title: 'Private Chef & Dining',
    tagline: 'Michelin-calibre, in complete privacy',
    image: 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=900&q=90',
  },
  {
    title: 'Exclusive Lodge Retreats',
    tagline: 'Seclusion without sacrifice',
    image: 'https://images.unsplash.com/photo-1566073771259-dc8b40b4d6ae?auto=format&fit=crop&w=900&q=90',
  },
  {
    title: 'Hot Air Balloon Journeys',
    tagline: 'Above it all, at golden hour',
    image: 'https://images.unsplash.com/photo-1507035895480-2b3156c31fc8?auto=format&fit=crop&w=900&q=90',
  },
  {
    title: 'Private Cellar Doors',
    tagline: 'Rare vintages, rarer access',
    image: 'https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?auto=format&fit=crop&w=900&q=90',
  },
  {
    title: 'Secluded Beach Access',
    tagline: 'Shores the world hasn\'t found yet',
    image: 'https://images.unsplash.com/photo-1506953823976-52e1fdc0149a?auto=format&fit=crop&w=900&q=90',
  },
];
---

<section style="background:#F5F0E9; padding: clamp(64px,8vw,120px) 0; overflow:hidden;">

  <!-- Header -->
  <div class="container-xl" style="margin-bottom: clamp(40px,4.5vw,64px);">
    <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:24px; flex-wrap:wrap;">
      <div>
        <div class="overline mb-4" data-reveal>curated for you</div>
        <h2
          class="display text-navy"
          style="font-size:clamp(32px,3.5vw,52px); line-height:1.05; letter-spacing:0.02em;"
          data-reveal data-delay="100"
        >
          The Art of<br/>Extraordinary
        </h2>
      </div>
      <p
        class="type-body-font"
        style="font-size:clamp(14px,1vw,16px); line-height:1.8; color:rgba(17,34,80,0.6); max-width:380px; font-style:italic;"
        data-reveal="right" data-delay="150"
      >
        From superyachts to secret cellars, every experience we arrange
        is private, considered, and entirely yours.
      </p>
    </div>
  </div>

  <!-- Carousel -->
  <div style="position:relative;">

    <!-- Prev -->
    <button id="exp-prev" class="exp-arrow" aria-label="Previous" style="left:clamp(12px,2vw,40px);">
      <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
        <path d="M9 1L1 7l8 6M1 7h16" stroke="currentColor" stroke-width="1.2"/>
      </svg>
    </button>

    <!-- Next -->
    <button id="exp-next" class="exp-arrow" aria-label="Next" style="right:clamp(12px,2vw,40px);">
      <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
        <path d="M9 1l8 6-8 6M17 7H1" stroke="currentColor" stroke-width="1.2"/>
      </svg>
    </button>

    <!-- Track -->
    <div id="exp-track" style="
      display:flex;
      gap:clamp(8px,1vw,14px);
      overflow-x:scroll;
      scrollbar-width:none;
      padding: 0 clamp(20px,5vw,80px);
      cursor:grab;
    ">
      {experiences.map(({ title, tagline, image }) => (
        <div class="exp-card" tabindex="0">
          <!-- Photo -->
          <img src={image} alt={title} class="exp-img" loading="lazy" decoding="async" width="900" height="1200" />

          <!-- Hover overlay -->
          <div class="exp-overlay">
            <div class="exp-overlay-inner">
              <span class="exp-overlay-top-rule"></span>
              <h3 class="type-heading-font exp-overlay-title">{title}</h3>
              <div class="exp-overlay-rule"></div>
              <p class="type-body-font exp-overlay-tagline">{tagline}</p>
              <span class="exp-overlay-cta type-body-font">
                Explore More
                <svg width="12" height="8" viewBox="0 0 14 10" fill="none" style="margin-left:6px;">
                  <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
                </svg>
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* Arrow buttons */
  .exp-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: clamp(40px,3vw,52px);
    height: clamp(40px,3vw,52px);
    border: 1px solid rgba(17,34,80,0.3);
    border-radius: 50%;
    background: rgba(245,240,233,0.85);
    backdrop-filter: blur(10px);
    color: #112250;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }
  .exp-arrow:hover {
    background: #112250;
    color: #F5F0E9;
    border-color: #112250;
  }

  /* Track */
  #exp-track::-webkit-scrollbar { display: none; }
  #exp-track.is-dragging { cursor: grabbing; }

  /* Card */
  .exp-card {
    flex: 0 0 clamp(240px,26vw,360px);
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/4;
    outline: none;
  }

  .exp-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .exp-card:hover .exp-img,
  .exp-card:focus-visible .exp-img {
    transform: scale(1.08);
  }

  /* Hover overlay */
  .exp-overlay {
    position: absolute;
    inset: 0;
    background: rgba(17,34,80,0.88);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .exp-card:hover .exp-overlay,
  .exp-card:focus-visible .exp-overlay {
    opacity: 1;
    transform: translateY(0);
  }

  .exp-overlay-inner {
    text-align: center;
    padding: clamp(24px,3vw,48px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .exp-overlay-top-rule {
    display: block;
    width: 32px;
    height: 1px;
    background: #C9A96E;
    margin-bottom: 20px;
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
    transition: opacity 0.4s ease 0.05s, transform 0.4s ease 0.05s;
  }

  .exp-card:hover .exp-overlay-top-rule,
  .exp-card:focus-visible .exp-overlay-top-rule {
    opacity: 1;
    transform: scaleX(1);
  }

  .exp-overlay-title {
    color: #F5F0E9;
    font-size: clamp(16px,1.4vw,22px);
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.2;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease 0.1s, transform 0.4s ease 0.1s;
  }

  .exp-card:hover .exp-overlay-title,
  .exp-card:focus-visible .exp-overlay-title {
    opacity: 1;
    transform: translateY(0);
  }

  .exp-overlay-rule {
    width: 32px;
    height: 1px;
    background: #C9A96E;
    margin: 16px auto;
    opacity: 0;
    transform: scaleX(0);
    transform-origin: center;
    transition: opacity 0.4s ease 0.18s, transform 0.4s ease 0.18s;
  }

  .exp-card:hover .exp-overlay-rule,
  .exp-card:focus-visible .exp-overlay-rule {
    opacity: 1;
    transform: scaleX(1);
  }

  .exp-overlay-tagline {
    color: rgba(245,240,233,0.65);
    font-size: clamp(12px,0.85vw,14px);
    font-style: italic;
    letter-spacing: 0.05em;
    line-height: 1.6;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease 0.22s, transform 0.4s ease 0.22s;
  }

  .exp-card:hover .exp-overlay-tagline,
  .exp-card:focus-visible .exp-overlay-tagline {
    opacity: 1;
    transform: translateY(0);
  }

  .exp-overlay-cta {
    display: inline-flex;
    align-items: center;
    margin-top: 24px;
    color: #C9A96E;
    font-size: clamp(10px,0.7vw,12px);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease 0.28s, transform 0.4s ease 0.28s;
    border-bottom: 1px solid rgba(201,169,110,0.4);
    padding-bottom: 3px;
  }

  .exp-card:hover .exp-overlay-cta,
  .exp-card:focus-visible .exp-overlay-cta {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('exp-track') as HTMLElement;
    const prevBtn = document.getElementById('exp-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('exp-next') as HTMLButtonElement;

    // ── Infinite loop: clone all cards ──────────────────────
    const origCards = Array.from(track.querySelectorAll<HTMLElement>('.exp-card'));
    const gap = () => parseFloat(getComputedStyle(track).gap) || 12;
    const cardW = () => origCards[0].offsetWidth + gap();

    // Prepend + append clones
    const clonesStart = origCards.map(c => { const cl = c.cloneNode(true) as HTMLElement; cl.setAttribute('aria-hidden','true'); return cl; });
    const clonesEnd   = origCards.map(c => { const cl = c.cloneNode(true) as HTMLElement; cl.setAttribute('aria-hidden','true'); return cl; });

    clonesEnd.forEach(c => track.appendChild(c));
    clonesStart.reverse().forEach(c => track.insertBefore(c, track.firstChild));

    // Jump to real start (after prepended clones)
    const jumpToReal = () => {
      track.scrollLeft = cardW() * origCards.length;
    };
    jumpToReal();

    // Seamless loop check
    track.addEventListener('scroll', () => {
      const total = cardW() * origCards.length;
      if (track.scrollLeft >= total * 2) {
        track.scrollLeft -= total;
      } else if (track.scrollLeft <= 0) {
        track.scrollLeft += total;
      }
    }, { passive: true });

    // Buttons
    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: cardW(), behavior: 'smooth' });
    });
    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -cardW(), behavior: 'smooth' });
    });

    // Drag to scroll
    let isDown = false, startX = 0, scrollLeft = 0;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      track.classList.add('is-dragging');
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });
    document.addEventListener('mouseup', () => { isDown = false; track.classList.remove('is-dragging'); });
    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      track.scrollLeft = scrollLeft - (x - startX) * 1.5;
    });
  });
</script>
