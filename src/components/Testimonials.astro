---
const testimonials = [
  {
    quote: 'Halcyon didn\'t just plan a trip — they created a journey that changed how we see the world. Every single day was perfectly considered.',
    name: 'Victoria & James H.',
    origin: 'London, United Kingdom',
    journey: 'South Island Grand Tour',
  },
  {
    quote: 'The access Halcyon arranged was simply impossible to find anywhere else. Places we didn\'t even know existed. Pure magic.',
    name: 'Andreas K.',
    origin: 'Zurich, Switzerland',
    journey: 'Northland Private Sail',
  },
  {
    quote: 'From the very first email, we felt we were in extraordinarily capable hands. The result was the finest travel experience of our lives.',
    name: 'Sarah & David M.',
    origin: 'New York, USA',
    journey: 'Australia\'s Red Centre & Reef',
  },
];
---

<section class="section-pad" style="background:#F5F0E9; position:relative; overflow:hidden;">

  <!-- Large decorative quote mark -->
  <div
    class="quote-mark"
    style="position:absolute; top:40px; left:50%; transform:translateX(-50%); pointer-events:none; user-select:none;"
    aria-hidden="true"
  >
    &ldquo;
  </div>

  <div class="container-lg">

    <div class="flex flex-col items-center text-center mb-16">
      <div class="overline mb-6" data-reveal>partner stories</div>
      <h2
        class="display text-navy"
        style="font-size:clamp(40px,5vw,72px); line-height:1.05;"
        data-reveal
        data-delay="100"
      >
        What Our Partners Say
      </h2>
    </div>

    <!-- Testimonial grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">
      {testimonials.map(({ quote, name, origin, journey }, i) => (
        <div
          class="flex flex-col"
          data-reveal
          data-delay={String(i * 140)}
        >
          <!-- Top rule -->
          <div style="width:100%; height:1px; background:rgba(17,34,80,0.12); margin-bottom:28px;"></div>

          <p
            class="type-body-font"
            style="
              font-size:clamp(15px,1.5vw,17px);
              font-style:italic;
              line-height:1.9;
              color:rgba(17,34,80,0.75);
              flex:1;
              margin-bottom:28px;
            "
          >
            &ldquo;{quote}&rdquo;
          </p>

          <div style="display:flex; flex-direction:column; gap:4px;">
            <div
              class="text-navy type-heading-font"
              style="font-size:15px; font-weight:400; letter-spacing:0.08em;"
            >
              {name}
            </div>
            <div
              class="type-body-font"
              style="font-size:11px; font-style:italic; letter-spacing:0.12em; color:rgba(17,34,80,0.4);"
            >
              {origin}
            </div>
            <div
              class="type-body-font"
              style="font-size:10px; font-style:italic; letter-spacing:0.15em; color:rgba(17,34,80,0.35); margin-top:6px;"
            >
              {journey}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
