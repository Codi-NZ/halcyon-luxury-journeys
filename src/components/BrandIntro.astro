<!-- Brand Introduction — editorial statement, calm cream section -->
<section class="section-pad" style="background:#F5F0E9; position:relative; overflow:hidden;">

  <div class="container-lg">

    <div class="flex flex-col items-center text-center mb-20">
      <div class="overline mb-8" data-reveal data-delay="0">about halcyon</div>

      <h2
        class="display text-navy"
        style="font-size:clamp(26px,3vw,42px); max-width:820px; line-height:1.15;"
        data-reveal
        data-delay="100"
      >
        Where the World's Most Beautiful Places Become Your Story
      </h2>

      <div style="width:1px; height:64px; background:rgba(17,34,80,0.15); margin:36px 0;" data-reveal data-delay="200"></div>

      <p
        class="type-body-font"
        style="font-size:clamp(15px,1.6vw,18px); line-height:1.9; color:rgba(17,34,80,0.7); max-width:640px; font-style:italic;"
        data-reveal
        data-delay="300"
      >
        Halcyon was founded on a single belief — that extraordinary travel should feel effortless. We design private journeys through New Zealand and Australia that go far beyond the expected, revealing landscapes, cultures, and experiences available only to those who know where to look.
      </p>
    </div>

    <!-- Three brand pillars -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-6 lg:gap-12">

      {[
        {
          num: '01',
          title: 'Private & Bespoke',
          body: 'Every journey is designed uniquely for you — your interests, your pace, your vision. No group tours. No compromises.',
        },
        {
          num: '02',
          title: 'Curated Expertise',
          body: 'Decades of destination knowledge distilled into experiences that reveal the true character of Aotearoa and Australia.',
        },
        {
          num: '03',
          title: 'Refined & Effortless',
          body: 'From the first conversation to your final evening, every detail is considered so you can be fully present.',
        },
      ].map(({ num, title, body }, i) => (
        <div
          class="flex flex-col items-center text-center"
          data-reveal
          data-delay={String(i * 150)}
        >
          <div
            style="font-family:'Cormorant Unicase',serif; font-size:11px; font-weight:400; letter-spacing:0.3em; color:rgba(17,34,80,0.3); margin-bottom:20px;"
          >
            {num}
          </div>
          <div style="width:1px; height:40px; background:rgba(17,34,80,0.15); margin-bottom:20px;"></div>
          <h3
            class="text-navy type-heading-font"
            style="font-size:22px; font-weight:400; letter-spacing:0.08em; margin-bottom:14px;"
          >
            {title}
          </h3>
          <p
            class="type-body-font"
            style="font-size:14px; line-height:1.9; color:rgba(17,34,80,0.6); font-style:italic;"
          >
            {body}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
