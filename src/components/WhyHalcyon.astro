---
const pillars = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="14" cy="14" r="13" stroke="#112250" stroke-width="0.8" opacity="0.2"/>
      <path d="M14 6v8l5 3" stroke="#112250" stroke-width="1" stroke-linecap="round"/>
    </svg>`,
    title: 'Completely Private',
    body: 'Your journey belongs only to you. No shared itineraries, no compromise on preference.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 14 Q14 4 24 14 Q14 24 4 14Z" stroke="#112250" stroke-width="0.8" opacity="0.3"/>
      <circle cx="14" cy="14" r="3" stroke="#112250" stroke-width="1"/>
    </svg>`,
    title: 'Insider Access',
    body: 'Deep relationships with lodges, guides, and operators unlock experiences beyond public reach.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M14 4 L16 10 L22 10 L17.5 13.5 L19.5 20 L14 16 L8.5 20 L10.5 13.5 L6 10 L12 10Z" stroke="#112250" stroke-width="0.8" opacity="0.3" fill="none"/>
    </svg>`,
    title: 'Exceptional Quality',
    body: 'Every lodge, transfer, and experience is handpicked against the highest standards of luxury.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M8 20 Q14 8 20 20" stroke="#112250" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>
      <circle cx="8" cy="20" r="2" stroke="#112250" stroke-width="1"/>
      <circle cx="20" cy="20" r="2" stroke="#112250" stroke-width="1"/>
      <circle cx="14" cy="8" r="2" stroke="#112250" stroke-width="1"/>
    </svg>`,
    title: 'End-to-End Care',
    body: 'From first enquiry to final farewell, our team is available every step of the journey.',
  },
];
---

<section class="section-pad" style="background:#F5F0E9; position:relative;">

  <div class="container-xl">

    <div class="flex flex-col items-center text-center mb-20">
      <div class="overline mb-6" data-reveal>why halcyon</div>
      <h2
        class="display text-navy"
        style="font-size:clamp(40px,5.5vw,80px); line-height:1.05; max-width:700px;"
        data-reveal
        data-delay="100"
      >
        Travel as it Was Meant to Be
      </h2>
      <div style="width:1px; height:48px; background:rgba(17,34,80,0.15); margin-top:32px;" data-reveal data-delay="200"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      {pillars.map(({ icon, title, body }, i) => (
        <div
          class="flex flex-col items-center text-center"
          data-reveal
          data-delay={String(i * 120)}
        >
          <!-- Icon -->
          <div style="margin-bottom:20px; opacity:0.8;" set:html={icon} />

          <!-- Thin rule -->
          <div style="width:32px; height:1px; background:rgba(17,34,80,0.2); margin-bottom:20px;"></div>

          <h3
            class="text-navy type-heading-font"
            style="font-size:20px; font-weight:400; letter-spacing:0.08em; margin-bottom:12px; line-height:1.3;"
          >
            {title}
          </h3>
          <p
            class="type-body-font"
            style="font-size:13.5px; font-style:italic; color:rgba(17,34,80,0.6); line-height:1.85;"
          >
            {body}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
