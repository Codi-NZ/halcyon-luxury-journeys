---
const destinations = [
  {
    name: 'New Zealand',
    region: 'Aotearoa',
    description: 'At the edge of the Pacific, New Zealand offers a world apart — ancient fjords carved by ice, volcanic highlands still breathing, and a culture of warmth that welcomes only those who truly seek it. Here, luxury is not in what you see but in how it makes you feel: the silence of Milford Sound at dawn, a private lodge above a lake that reflects the stars, a meal prepared just for you from the land you\'re standing on.',
    image: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=1400&q=85',
    slug: '/destinations/new-zealand',
  },
  {
    name: 'Australia',
    region: 'The Great South Land',
    description: 'Australia defies any single description. It is the impossibly blue archipelago of the Whitsundays, the sacred stillness of Uluru at first light, the raw and untamed beauty of the Kimberley — a continent of contrasts so vast and so varied that a lifetime is barely enough. We know where to take you, and we know how to make it feel like it was made for you alone.',
    image: 'https://images.unsplash.com/photo-1523482580672-f109ba8cb9be?auto=format&fit=crop&w=1400&q=85',
    slug: '/destinations/australia',
  },
];
---

<section class="section-pad" style="background:#ffffff;">
  <div class="container-xl">

    <!-- Header -->
    <div
      style="
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:clamp(40px,6vw,120px);
        align-items:end;
        padding-bottom:clamp(56px,7vw,96px);
        border-bottom:1px solid rgba(17,34,80,0.12);
      "
    >
      <div>
        <div class="overline mb-4" data-reveal>our destinations</div>
        <h2
          class="display text-navy"
          style="font-size:clamp(32px,3.5vw,52px); line-height:1.05; letter-spacing:0.02em;"
          data-reveal
          data-delay="100"
        >
          Two Countries.<br/>Infinite Journeys.
        </h2>
      </div>

      <div data-reveal="right" data-delay="150">
        <p
          class="type-body-font"
          style="font-size:clamp(15px,1.1vw,18px); line-height:1.8; color:rgba(17,34,80,0.68);"
        >
          We have devoted ourselves entirely to New Zealand and Australia — not because
          they are convenient, but because we believe they are among the most extraordinary
          places on earth. Two destinations. Mastered completely.
        </p>
      </div>
    </div>

    <!-- Two accordion rows -->
    <div>
      {destinations.map(({ name, region, description, image, slug }, i) => (
        <div class="accordion-item" data-reveal data-delay={String(i * 80)}>

          <button
            class="accordion-trigger"
            aria-expanded="false"
            aria-controls={`dest-panel-${i}`}
            id={`dest-trigger-${i}`}
          >
            <span class="accordion-num type-body-font">0{i + 1}</span>
            <span class="accordion-name type-heading-font">{name}</span>
            <span class="accordion-sub type-body-font">{region}</span>
            <span class="accordion-icon" aria-hidden="true">+</span>
          </button>

          <div
            class="accordion-panel"
            id={`dest-panel-${i}`}
            role="region"
            aria-labelledby={`dest-trigger-${i}`}
          >
            <div class="accordion-panel-inner">
              <div class="accordion-panel-grid">
                <div class="accordion-img-wrap">
                  <img
                    src={image}
                    alt={name}
                    class="accordion-img"
                    loading="lazy"
                    decoding="async"
                    width="700"
                    height="400"
                  />
                </div>
                <div class="accordion-content">
                  <p class="type-body-font accordion-desc">{description}</p>
                  <a href={slug} class="btn-luxury" style="display:inline-flex; margin-top:28px;">
                    Discover {name}
                    <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
                      <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>

        </div>
      ))}
      <div style="border-top:1px solid rgba(17,34,80,0.12);"></div>
    </div>

  </div>
</section>

<style>
  .accordion-item {
    border-top: 1px solid rgba(17,34,80,0.12);
  }

  .accordion-trigger {
    width: 100%;
    display: grid;
    grid-template-columns: clamp(36px,3vw,56px) 1fr auto auto;
    align-items: center;
    gap: clamp(16px,3vw,48px);
    padding: clamp(24px,2.8vw,40px) 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  .accordion-num {
    font-size: clamp(10px,0.7vw,12px);
    letter-spacing: 0.2em;
    color: rgba(17,34,80,0.3);
    font-style: italic;
  }

  .accordion-name {
    font-size: clamp(32px,4.5vw,68px);
    font-weight: 400;
    letter-spacing: 0.03em;
    color: #112250;
    line-height: 1;
    transition: opacity 0.2s ease;
  }

  .accordion-trigger:hover .accordion-name {
    opacity: 0.65;
  }

  .accordion-sub {
    font-size: clamp(11px,0.75vw,13px);
    font-style: italic;
    letter-spacing: 0.12em;
    color: rgba(17,34,80,0.4);
    white-space: nowrap;
  }

  .accordion-icon {
    width: clamp(36px,2.8vw,48px);
    height: clamp(36px,2.8vw,48px);
    border: 1px solid rgba(17,34,80,0.25);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: rgba(17,34,80,0.5);
    font-size: 22px;
    font-weight: 300;
    font-family: 'Lato', sans-serif;
    transition: all 0.25s ease;
    line-height: 1;
  }

  .accordion-trigger[aria-expanded="true"] .accordion-icon {
    background: #112250;
    border-color: #112250;
    color: #F5F0E9;
  }

  /* Panel animation */
  .accordion-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .accordion-panel.is-open {
    grid-template-rows: 1fr;
  }

  .accordion-panel-inner {
    overflow: hidden;
  }

  .accordion-panel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px,5vw,80px);
    padding-bottom: clamp(36px,4vw,64px);
    align-items: center;
  }

  .accordion-img-wrap {
    overflow: hidden;
    aspect-ratio: 16/10;
  }

  .accordion-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .accordion-img-wrap:hover .accordion-img {
    transform: scale(1.04);
  }

  .accordion-desc {
    font-size: clamp(14px,1.05vw,17px);
    line-height: 1.85;
    color: rgba(17,34,80,0.65);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .accordion-trigger {
      grid-template-columns: clamp(28px,3vw,40px) 1fr auto;
    }
    .accordion-sub { display: none; }
    .accordion-panel-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll<HTMLButtonElement>('.accordion-trigger');

    triggers.forEach((trigger) => {
      const icon = trigger.querySelector('.accordion-icon');
      if (icon) icon.textContent = '+';

      trigger.addEventListener('click', () => {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        const panel = document.getElementById(trigger.getAttribute('aria-controls')!)!;

        // Close all others
        triggers.forEach((t) => {
          if (t !== trigger) {
            t.setAttribute('aria-expanded', 'false');
            document.getElementById(t.getAttribute('aria-controls')!)!.classList.remove('is-open');
            const ic = t.querySelector('.accordion-icon');
            if (ic) ic.textContent = '+';
          }
        });

        const next = !isOpen;
        trigger.setAttribute('aria-expanded', String(next));
        panel.classList.toggle('is-open', next);
        if (icon) icon.textContent = next ? '−' : '+';
      });
    });
  });
</script>
