---
// Concept 3 Hero — Viselli-inspired: full-screen video, minimal centered text, imagery does the work
---

<section id="c3-hero" aria-label="Halcyon Luxury Journeys">

  <div class="c3-hero-bg">
    <video
      autoplay muted loop playsinline preload="metadata"
      aria-hidden="true"
    >
      <source src="/207717_medium.mp4" type="video/mp4" />
      <source src="/14695245-hd_1920_1080_30fps.mp4" type="video/mp4" />
    </video>
    <div class="c3-hero-overlay"></div>
  </div>

  <!-- Minimal centred identity -->
  <div class="c3-hero-content">
    <p class="c3-hero-wordmark">Halcyon</p>
    <div class="c3-hero-rule" aria-hidden="true"></div>
    <p class="c3-hero-tagline">
      Bespoke journeys through New Zealand &amp; Australia
    </p>
  </div>

  <!-- Scroll cue, bottom centre -->
  <div class="c3-hero-scroll" aria-hidden="true">
    <div class="c3-scroll-line"></div>
  </div>

</section>

<style>
  #c3-hero {
    position: relative;
    width: 100%;
    min-height: 78vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Video */
  .c3-hero-bg {
    position: absolute;
    inset: 0;
  }
  .c3-hero-bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }
  .c3-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(11, 23, 56, 0.45) 0%,
      rgba(11, 23, 56, 0.55) 50%,
      rgba(11, 23, 56, 0.70) 100%
    );
  }

  /* Content — very restrained */
  .c3-hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
    opacity: 0;
    animation: c3HeroIn 1.4s ease forwards 0.6s;
  }
  .c3-hero-wordmark {
    font-family: 'Cormorant Unicase', serif;
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 300;
    letter-spacing: 0.38em;
    color: #F5F0E9;
    margin: 0;
    text-transform: uppercase;
  }
  .c3-hero-rule {
    width: 48px;
    height: 1px;
    background: rgba(245, 240, 233, 0.45);
    margin: 20px auto;
  }
  .c3-hero-tagline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(13px, 1.2vw, 16px);
    font-style: italic;
    font-weight: 300;
    letter-spacing: 0.12em;
    color: rgba(245, 240, 233, 0.78);
    margin: 0;
  }

  /* Scroll indicator */
  .c3-hero-scroll {
    position: absolute;
    bottom: clamp(28px, 4vh, 48px);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    opacity: 0;
    animation: c3HeroIn 1s ease forwards 1.8s;
  }
  .c3-scroll-line {
    width: 1px;
    height: 52px;
    background: rgba(245, 240, 233, 0.25);
    position: relative;
    overflow: hidden;
  }
  .c3-scroll-line::after {
    content: '';
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(245, 240, 233, 0.7);
    animation: c3ScrollDrop 2.2s ease infinite 2.6s;
  }

  @keyframes c3HeroIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes c3ScrollDrop {
    0%   { top: -100%; }
    100% { top: 100%; }
  }
</style>
