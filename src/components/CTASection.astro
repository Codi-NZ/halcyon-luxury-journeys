<!-- Full-bleed CTA — cinematic image with overlay -->
<section style="position:relative; min-height:560px; display:flex; align-items:center; justify-content:center; overflow:hidden;">

  <!-- Background image -->
  <img
    src="https://picsum.photos/seed/nz-lake-reflection/2400/1200"
    alt="Lake Matheson reflection, New Zealand"
    style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;"
    loading="lazy"
    decoding="async"
  />

  <!-- Overlay -->
  <div
    style="position:absolute; inset:0; background:linear-gradient(135deg, rgba(17,34,80,0.78) 0%, rgba(17,34,80,0.55) 100%);"
  ></div>

  <!-- Content -->
  <div
    class="container-lg"
    style="position:relative; z-index:1; display:flex; flex-direction:column; align-items:center; text-align:center; padding-top:80px; padding-bottom:80px;"
  >
    <div class="overline-light mb-8" data-reveal>ready to begin</div>

    <h2
      class="display"
      style="font-size:clamp(48px,7vw,96px); color:#F5F0E9; line-height:1; margin-bottom:24px; max-width:800px;"
      data-reveal
      data-delay="100"
    >
      Your Journey<br />
      <em style="font-style:normal; color:rgba(201,233,255,0.85);">Awaits</em>
    </h2>

    <p
      class="type-body-font"
      style="font-size:clamp(14px,1.5vw,17px); font-style:italic; color:rgba(245,240,233,0.7); line-height:1.9; max-width:480px; margin-bottom:48px;"
      data-reveal
      data-delay="200"
    >
      Every extraordinary journey begins with a conversation. Share your vision and we will craft something truly remarkable.
    </p>

    <div class="flex flex-col sm:flex-row items-center gap-5" data-reveal data-delay="300">
      <a href="/enquire" class="btn-filled btn-filled-light">
        Begin an Enquiry
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
          <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
        </svg>
      </a>
      <a href="/journeys" class="btn-luxury btn-luxury-light">
        Browse Journeys
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
          <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
        </svg>
      </a>
    </div>

    <!-- Reassurance line -->
    <div
      style="margin-top:40px; display:flex; align-items:center; gap:24px; flex-wrap:wrap; justify-content:center;"
      data-reveal
      data-delay="400"
    >
      {['Fully Private', 'No Obligation', 'Expert Guidance'].map((item) => (
        <span
          class="type-body-font"
          style="font-size:10px; font-style:italic; letter-spacing:0.2em; color:rgba(245,240,233,0.4);"
        >
          {item}
        </span>
        <span style="width:3px; height:3px; border-radius:50%; background:rgba(245,240,233,0.2); last-child:display:none;"></span>
      ))}
    </div>
  </div>
</section>
