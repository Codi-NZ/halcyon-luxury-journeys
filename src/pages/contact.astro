---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="Contact — Halcyon Luxury Journeys"
  description="Partner With Us — begin the conversation about your extraordinary journey."
>
  <Header />
  <main>
    <section class="page-hero">
      <div class="page-hero-inner">
        <p class="eyebrow" data-reveal>Contact Us</p>
        <h1 class="page-title" data-reveal data-delay="100">Partner With Us</h1>
        <p class="page-intro" data-reveal data-delay="200">
          Every extraordinary journey begins with a conversation.
          Tell us your vision — we'll take care of everything else.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    background: #F5F0E9;
    padding: clamp(80px, 12vw, 160px) 0 clamp(60px, 8vw, 100px);
    border-bottom: 1px solid rgba(17, 34, 80, 0.08);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .page-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(24px, 6vw, 100px);
  }
  .eyebrow {
    font-family: 'Cormorant Unicase', serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #C9A96E;
    margin-bottom: 24px;
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .eyebrow.revealed { opacity: 1; transform: translateY(0); }
  .page-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(42px, 6vw, 88px);
    font-weight: 400;
    line-height: 1.05;
    color: #112250;
    margin-bottom: 32px;
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .page-title.revealed { opacity: 1; transform: translateY(0); }
  .page-intro {
    font-family: 'Cormorant Unicase', serif;
    font-size: clamp(15px, 1.2vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: rgba(17, 34, 80, 0.6);
    max-width: 520px;
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .page-intro.revealed { opacity: 1; transform: translateY(0); }
</style>
