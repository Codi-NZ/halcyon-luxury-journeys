---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="Contact — Halcyon Luxury Journeys"
  description="Partner With Us — begin the conversation about your extraordinary journey."
>
  <Header />
  <main>

    <!-- ── Page Hero ─────────────────────────────────────── -->
    <section class="page-hero">
      <div class="page-hero-inner">
        <p class="eyebrow" data-reveal>Contact Us</p>
        <h1 class="page-title" data-reveal data-delay="100">Begin the<br />Conversation</h1>
        <p class="page-intro" data-reveal data-delay="200">
          Every extraordinary journey begins with a single question.
          Tell us what calls to you — we'll take care of everything else.
        </p>
      </div>
    </section>

    <!-- ── Contact Body ──────────────────────────────────── -->
    <section class="contact-section">
      <div class="contact-inner">

        <!-- Left: Get in Touch details -->
        <div class="contact-details" data-reveal="left">

          <div class="overline mb-8">Get in touch</div>

          <p class="contact-details-intro">
            We work with a small number of clients at any one time — which means when you reach out,
            you speak directly with someone who will design your journey personally.
          </p>

          <div class="contact-items">

            <div class="contact-item">
              <div class="contact-item-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2 4.5C2 3.67 2.67 3 3.5 3h13C17.33 3 18 3.67 18 4.5v11c0 .83-.67 1.5-1.5 1.5h-13C2.67 17 2 16.33 2 15.5v-11Z" stroke="#C9A96E" stroke-width="1.2"/>
                  <path d="M2 5l8 5.5L18 5" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="contact-item-content">
                <p class="contact-item-label">Email</p>
                <a href="mailto:hello@halcyonluxuryjourneys.com" class="contact-item-value">
                  hello@halcyonluxuryjourneys.com
                </a>
              </div>
            </div>

            <div class="contact-item">
              <div class="contact-item-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M5.5 2h-1A1.5 1.5 0 0 0 3 3.5v1C3 11.96 8.04 17 14.5 17h1A1.5 1.5 0 0 0 17 15.5v-1a.5.5 0 0 0-.31-.46l-3-1.25a.5.5 0 0 0-.57.14l-1.2 1.46a8.51 8.51 0 0 1-4.31-4.31l1.46-1.2a.5.5 0 0 0 .14-.57l-1.25-3A.5.5 0 0 0 7.5 4H6" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="contact-item-content">
                <p class="contact-item-label">Phone</p>
                <a href="tel:+6421000000" class="contact-item-value">+64 21 000 000</a>
                <p class="contact-item-note">New Zealand · Mon – Fri, 9am – 6pm NZST</p>
              </div>
            </div>

            <div class="contact-item">
              <div class="contact-item-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="10" cy="9" r="3" stroke="#C9A96E" stroke-width="1.2"/>
                  <path d="M10 2a7 7 0 0 1 7 7c0 4-7 10-7 10S3 13 3 9a7 7 0 0 1 7-7Z" stroke="#C9A96E" stroke-width="1.2"/>
                </svg>
              </div>
              <div class="contact-item-content">
                <p class="contact-item-label">Based in</p>
                <p class="contact-item-value">Queenstown, New Zealand</p>
                <p class="contact-item-note">Designing journeys across NZ & Australia</p>
              </div>
            </div>

            <div class="contact-item">
              <div class="contact-item-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="2" y="5" width="16" height="13" rx="1.5" stroke="#C9A96E" stroke-width="1.2"/>
                  <path d="M14 5V4a2 2 0 0 0-4 0v1M6 5V4a2 2 0 0 0-4 0" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/>
                  <path d="M2 9h16" stroke="#C9A96E" stroke-width="1.2"/>
                </svg>
              </div>
              <div class="contact-item-content">
                <p class="contact-item-label">Response time</p>
                <p class="contact-item-value">Within 24 hours</p>
                <p class="contact-item-note">We read every enquiry personally</p>
              </div>
            </div>

          </div>

          <!-- Divider -->
          <div class="contact-details-rule"></div>

          <!-- Social links -->
          <div class="contact-social">
            <p class="contact-social-label">Follow the journey</p>
            <div class="contact-social-links">
              <a href="#" class="contact-social-link" aria-label="Instagram">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.4"/>
                  <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.4"/>
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                </svg>
                Instagram
              </a>
              <a href="#" class="contact-social-link" aria-label="Facebook">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3V2Z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Facebook
              </a>
            </div>
          </div>

        </div>

        <!-- Right: Enquiry Form -->
        <div class="contact-form-wrap" data-reveal="right" data-delay="100">
          <div class="overline mb-8">Send an enquiry</div>

          <form class="contact-form" name="contact" method="POST" novalidate>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="first-name">First name</label>
                <input class="form-input" type="text" id="first-name" name="first-name" placeholder="Your first name" required />
              </div>
              <div class="form-group">
                <label class="form-label" for="last-name">Last name</label>
                <input class="form-input" type="text" id="last-name" name="last-name" placeholder="Your last name" required />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="email">Email address</label>
              <input class="form-input" type="email" id="email" name="email" placeholder="you@example.com" required />
            </div>

            <div class="form-group">
              <label class="form-label" for="phone">Phone <span class="form-label-optional">— optional</span></label>
              <input class="form-input" type="tel" id="phone" name="phone" placeholder="+1 000 000 0000" />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="destination">Destination of interest</label>
                <div class="form-select-wrap">
                  <select class="form-select" id="destination" name="destination">
                    <option value="" disabled selected>Select a destination</option>
                    <option>New Zealand</option>
                    <option>Australia</option>
                    <option>Both / Combined</option>
                    <option>Not sure yet</option>
                  </select>
                  <svg class="form-select-chevron" width="12" height="8" viewBox="0 0 12 8" fill="none">
                    <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                  </svg>
                </div>
              </div>
              <div class="form-group">
                <label class="form-label" for="travel-dates">Approximate travel dates</label>
                <input class="form-input" type="text" id="travel-dates" name="travel-dates" placeholder="e.g. March 2026" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="travellers">Number of travellers</label>
              <div class="form-select-wrap">
                <select class="form-select" id="travellers" name="travellers">
                  <option value="" disabled selected>Select</option>
                  <option>2 — couple</option>
                  <option>3 – 4</option>
                  <option>5 – 8</option>
                  <option>9+</option>
                </select>
                <svg class="form-select-chevron" width="12" height="8" viewBox="0 0 12 8" fill="none">
                  <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="message">Tell us about your journey</label>
              <textarea
                class="form-textarea"
                id="message"
                name="message"
                rows="5"
                placeholder="A landscape, a feeling, a dream — tell us anything. There are no wrong answers."
                required
              ></textarea>
            </div>

            <button type="submit" class="form-submit">
              Send Enquiry
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
                <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
              </svg>
            </button>

            <p class="form-disclaimer">
              We never share your details. Every enquiry is read personally by Tracey or Steve.
            </p>

          </form>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>

  /* ── Page Hero ─────────────────────────────────────────── */
  .page-hero {
    background: #F5F0E9;
    padding: clamp(80px, 12vw, 160px) 0 clamp(60px, 8vw, 100px);
    border-bottom: 1px solid rgba(17, 34, 80, 0.08);
    min-height: 52vh;
    display: flex;
    align-items: center;
  }
  .page-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(24px, 6vw, 100px);
  }
  .eyebrow {
    font-family: 'Cormorant Unicase', serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #C9A96E;
    margin-bottom: 24px;
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .eyebrow.revealed { opacity: 1; transform: translateY(0); }
  .page-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(42px, 6vw, 88px);
    font-weight: 400;
    line-height: 1.05;
    color: #112250;
    margin-bottom: 32px;
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.7s ease 0.1s, transform 0.7s ease 0.1s;
  }
  .page-title.revealed { opacity: 1; transform: translateY(0); }
  .page-intro {
    font-family: 'Lato', sans-serif;
    font-size: clamp(15px, 1.2vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: rgba(17, 34, 80, 0.6);
    max-width: 520px;
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.7s ease 0.2s, transform 0.7s ease 0.2s;
  }
  .page-intro.revealed { opacity: 1; transform: translateY(0); }

  /* ── Contact Section ───────────────────────────────────── */
  .contact-section {
    background: #F5F0E9;
    padding: clamp(64px, 9vw, 120px) 0;
  }
  .contact-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(24px, 6vw, 100px);
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(48px, 7vw, 100px);
    align-items: start;
  }

  /* ── Details Column ────────────────────────────────────── */
  .contact-details {
    opacity: 0; transform: translateX(-28px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .contact-details.revealed { opacity: 1; transform: translateX(0); }

  .contact-details-intro {
    font-family: 'Lato', sans-serif;
    font-size: clamp(14px, 1.1vw, 16px);
    font-style: italic;
    line-height: 1.85;
    color: rgba(17, 34, 80, 0.6);
    margin-bottom: 40px;
  }

  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 28px;
    margin-bottom: 40px;
  }
  .contact-item {
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }
  .contact-item-icon {
    width: 36px;
    height: 36px;
    border: 1px solid rgba(201, 169, 110, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .contact-item-content { flex: 1; }
  .contact-item-label {
    font-family: 'Cormorant Unicase', serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #C9A96E;
    margin-bottom: 5px;
  }
  .contact-item-value {
    font-family: 'Playfair Display', serif;
    font-size: clamp(15px, 1.2vw, 17px);
    font-weight: 400;
    color: #112250;
    text-decoration: none;
    display: block;
    transition: color 0.2s ease;
  }
  a.contact-item-value:hover { color: #C9A96E; }
  .contact-item-note {
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    color: rgba(17, 34, 80, 0.4);
    margin-top: 4px;
    letter-spacing: 0.02em;
  }

  .contact-details-rule {
    width: 100%;
    height: 1px;
    background: rgba(17, 34, 80, 0.1);
    margin-bottom: 32px;
  }

  .contact-social-label {
    font-family: 'Cormorant Unicase', serif;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(17, 34, 80, 0.4);
    margin-bottom: 14px;
  }
  .contact-social-links {
    display: flex;
    gap: 20px;
  }
  .contact-social-link {
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: rgba(17, 34, 80, 0.55);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: color 0.2s ease;
  }
  .contact-social-link:hover { color: #C9A96E; }

  /* ── Form Column ───────────────────────────────────────── */
  .contact-form-wrap {
    background: #fff;
    padding: clamp(36px, 4vw, 56px);
    border: 1px solid rgba(17, 34, 80, 0.07);
    opacity: 0; transform: translateX(28px);
    transition: opacity 0.8s ease 0.1s, transform 0.8s ease 0.1s;
  }
  .contact-form-wrap.revealed { opacity: 1; transform: translateX(0); }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    font-family: 'Cormorant Unicase', serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(17, 34, 80, 0.55);
  }
  .form-label-optional {
    font-family: 'Lato', sans-serif;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.04em;
    text-transform: none;
    color: rgba(17, 34, 80, 0.35);
  }

  .form-input,
  .form-select,
  .form-textarea {
    font-family: 'Lato', sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: #112250;
    background: #F5F0E9;
    border: 1px solid rgba(17, 34, 80, 0.12);
    padding: 13px 16px;
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease;
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
    border-radius: 0;
  }
  .form-input::placeholder,
  .form-textarea::placeholder {
    color: rgba(17, 34, 80, 0.3);
    font-style: italic;
  }
  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    border-color: #C9A96E;
    background: #fff;
  }

  .form-select-wrap {
    position: relative;
  }
  .form-select {
    cursor: pointer;
    padding-right: 36px;
  }
  .form-select option[value=""][disabled] { color: rgba(17, 34, 80, 0.3); }
  .form-select-chevron {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: rgba(17, 34, 80, 0.4);
  }

  .form-textarea {
    resize: vertical;
    min-height: 130px;
    line-height: 1.7;
  }

  .form-submit {
    font-family: 'Playfair Display', serif;
    font-size: 12px;
    font-style: italic;
    letter-spacing: 0.2em;
    color: #F5F0E9;
    background: #112250;
    border: 1px solid #112250;
    padding: 16px 32px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    align-self: flex-start;
    transition: background 0.25s ease, color 0.25s ease, gap 0.25s ease;
  }
  .form-submit:hover {
    background: #C9A96E;
    border-color: #C9A96E;
    gap: 18px;
  }

  .form-disclaimer {
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    color: rgba(17, 34, 80, 0.35);
    line-height: 1.6;
    letter-spacing: 0.02em;
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 900px) {
    .contact-inner {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 520px) {
    .form-row { grid-template-columns: 1fr; }
    .contact-form-wrap { padding: 28px 20px; }
  }

</style>
