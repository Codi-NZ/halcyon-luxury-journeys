<script>
  // Parallax on origin image
  const originImg = document.getElementById('origin-img') as HTMLElement | null;
  if (originImg) {
    window.addEventListener('scroll', () => {
      const rect = originImg.parentElement!.getBoundingClientRect();
      const viewH = window.innerHeight;
      if (rect.bottom > 0 && rect.top < viewH) {
        const progress = (viewH - rect.top) / (viewH + rect.height);
        originImg.style.transform = `translateY(${(progress - 0.5) * -60}px)`;
      }
    }, { passive: true });
  }
</script>
