---
// ============================================================
// CONCEPT 2 — COMMENTED OUT (code preserved, not in use)
// Redirect to Concept 1 (main homepage)
// ============================================================
return Astro.redirect('/', 301);

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const accommodations = [
  {
    id: '01',
    name: 'Blanket Bay Lodge',
    region: 'Queenstown, New Zealand',
    type: 'Alpine Lodge',
    tag: 'Most Private',
    img: 'https://picsum.photos/seed/blanket-bay-lodge-nz/800/1100',
  },
  {
    id: '02',
    name: 'Huka Lodge',
    region: 'Taupo, New Zealand',
    type: 'River Retreat',
    tag: 'Icon of NZ',
    img: 'https://picsum.photos/seed/huka-lodge-taupo-nz/800/1100',
  },
  {
    id: '03',
    name: 'Longitude 131°',
    region: 'Uluru, Australia',
    type: 'Desert Retreat',
    tag: 'One of a Kind',
    img: 'https://picsum.photos/seed/longitude131-uluru-au/800/1100',
  },
];

const experiences = [
  {
    id: '01',
    title: 'Private Helicopter Escapes',
    tagline: 'Rise above. See beyond.',
    description: 'Unlock landscapes inaccessible by road — glacier landings, remote valley picnics, summit-to-summit Alpine flights with your personal pilot and nothing but silence ahead.',
    img: 'https://picsum.photos/seed/helicopter-alps-nz/1200/800',
  },
  {
    id: '02',
    title: 'Superyacht & Private Sail',
    tagline: 'Your own course to chart.',
    description: 'Explore the Bay of Islands or the Whitsundays aboard a private vessel — days anchored in deserted bays, mornings wrapped in silence, evenings entirely yours.',
    img: 'https://picsum.photos/seed/superyacht-bay-islands-nz/1200/800',
  },
  {
    id: '03',
    title: 'Private Chef & Cellar Doors',
    tagline: 'Taste the land, intimately.',
    description: "From Hawke's Bay to the Barossa Valley, access world-class producers after hours — guided tastings, private dinners beneath open skies, flavours you won't find on any menu.",
    img: 'https://picsum.photos/seed/private-chef-wine-nz/1200/800',
  },
];

const itineraries = [
  {
    id: '01',
    country: 'New Zealand',
    nights: '14 nights',
    title: 'The South Island Grand Tour',
    description: "Alpine grandeur, fiordland silence, and the intimacy of New Zealand's finest lodges — a journey of contrasts, beauty, and private discovery.",
    img: 'https://picsum.photos/seed/south-island-grand-c2/1400/900',
    highlights: ['Fiordland private charter', 'Helicopter to Franz Josef Glacier', 'Mount Cook landing', 'Exclusive lodge circuit'],
    slug: '/itineraries/south-island-grand-tour',
  },
  {
    id: '02',
    country: 'New Zealand',
    nights: '8 nights',
    title: 'Northland & Bay of Islands',
    description: 'Private sail through sapphire waters to hidden coves, historic shores, and island vineyards — the birthplace of modern New Zealand, reimagined.',
    img: 'https://picsum.photos/seed/northland-bay-c2/1400/900',
    highlights: ['Private yacht charter', 'Waitangi Treaty Grounds private visit', 'Cape Brett lighthouse', 'Coastal wine experience'],
    slug: '/itineraries/northland-bay-of-islands',
  },
  {
    id: '03',
    country: 'Australia',
    nights: '12 nights',
    title: "Australia's Red Centre & The Reef",
    description: "Ancient ochre desert meets luminous coral sea — two of Earth's most arresting landscapes, experienced through a lens of intimacy and insider access.",
    img: 'https://picsum.photos/seed/red-centre-reef-c2/1400/900',
    highlights: ['Uluru sunrise by private 4WD', 'Indigenous cultural experience', 'Private reef snorkel, Whitsundays', 'Seaplane to outer reef'],
    slug: '/itineraries/red-centre-and-reef',
  },
];

const pillars = [
  { title: 'Completely Private', body: 'Your journey, your pace — never shared with strangers.' },
  { title: 'Insider Access', body: 'Places and people most travellers will never encounter.' },
  { title: 'Exceptional Quality', body: 'From your lodge to your guide, nothing less than the best.' },
  { title: 'End-to-End Care', body: '24/7 support from first enquiry to your safe return home.' },
];
---

<Layout
  title="Halcyon Luxury Journeys — Concept 2"
  description="Halcyon curates extraordinary private journeys through New Zealand and Australia — bespoke, exclusive, unforgettable."
>
  <Header />

  <main>

    <!-- ─── 1. HERO ─────────────────────────────────────────────────── -->
    <section id="hero-c2" class="layout-outer" aria-label="Halcyon hero">
      <div class="c2-hero-wrap">

        <video
          class="c2-hero-video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-label="Scenic New Zealand and Australia travel footage"
        >
          <source src="/14861093_3840_2160_30fps.mp4" type="video/mp4" />
        </video>

        <div class="c2-hero-overlay"></div>

        <!-- Centered hero content -->
        <div class="c2-hero-content">

          <!-- Overline with flanking rules -->
          <div class="c2-hero-overline" data-reveal>
            <span class="c2-rule-h"></span>
            <span class="c2-dest-label">New Zealand · Australia</span>
            <span class="c2-rule-h"></span>
          </div>

          <!-- Headline -->
          <h1 class="c2-hero-h1" data-reveal data-delay="140">
            Where the<br />World Begins<br />to Slow
          </h1>

          <!-- Thin divider -->
          <div class="c2-hero-divider" data-reveal data-delay="220" aria-hidden="true"></div>

          <!-- Subheading -->
          <p class="c2-hero-sub" data-reveal data-delay="300">
            Private journeys through New Zealand and Australia, tailored with care for those who travel with intention.
          </p>

        </div>

        <!-- Scroll indicator -->
        <div class="scroll-indicator" aria-hidden="true">
          <div class="scroll-line"></div>
          <span>scroll</span>
        </div>

        <!-- Vertical location label -->
        <div class="c2-hero-location" aria-hidden="true">
          <span class="c2-location-text">Aotearoa New Zealand</span>
        </div>

      </div>
    </section>


    <!-- ─── 2. BRAND STATEMENT ───────────────────────────────────────── -->
    <section class="layout-outer bg-cream section-pad" aria-label="Brand philosophy">
      <div class="c2-statement-wrap">

        <div class="c2-statement-eyebrow" data-reveal>
          <span class="c2-statement-rule"></span>
          <span class="overline">since 2010</span>
          <span class="c2-statement-rule"></span>
        </div>

        <blockquote class="c2-statement-quote" data-reveal data-delay="100">
          "We don't sell packages. We listen, we design, and we bring the hidden side of these extraordinary lands to light — for travellers who know the difference."
        </blockquote>

        <div class="c2-statement-sig" data-reveal data-delay="200">
          <span class="c2-statement-sig-rule"></span>
          <span class="c2-statement-sig-name">Halcyon Luxury Journeys</span>
        </div>

      </div>
    </section>


    <!-- ─── 3. FEATURED ACCOMMODATION ───────────────────────────────── -->
    <section class="layout-outer section-pad c2-accom-section" aria-label="Featured accommodation">
      <div class="container-xl">

        <div class="c2-section-header" data-reveal>
          <span class="overline">where you stay</span>
          <h2 class="c2-section-h2">Exceptional<br />Places to Stay</h2>
          <p class="c2-section-intro">
            Each property chosen for its soul, setting, and the way it makes you feel the landscape all around you.
          </p>
        </div>

        <!-- 3-column card grid -->
        <div class="c2-accom-grid">
          {accommodations.map((stay, i) => (
            <div class="c2-stay-card" data-reveal data-delay={String(i * 110)}>
              <div class="c2-stay-img-wrap">
                <div class="c2-stay-badge">
                  <span class="c2-stay-badge-text">{stay.tag}</span>
                </div>
                <div class="c2-stay-num" aria-hidden="true">{stay.id}</div>
                <img
                  src={stay.img}
                  alt={stay.name}
                  class="c2-stay-img"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="c2-stay-body">
                <div class="c2-stay-meta">
                  <span class="c2-stay-type">{stay.type}</span>
                  <span class="c2-stay-divider" aria-hidden="true"></span>
                  <span class="c2-stay-region">{stay.region}</span>
                </div>
                <h3 class="c2-stay-name">{stay.name}</h3>
                <a href="/accommodation" class="btn-luxury c2-stay-link">
                  Explore stay
                  <svg width="12" height="9" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                    <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>

        <div class="c2-view-all" data-reveal>
          <a href="/accommodation" class="btn-filled">
            View All Accommodation
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
              <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
            </svg>
          </a>
        </div>

      </div>
    </section>


    <!-- ─── 4. CURATED EXPERIENCES ───────────────────────────────────── -->
    <section class="layout-outer section-pad c2-exp-section" aria-label="Curated experiences">
      <div class="c2-exp-bg-word" aria-hidden="true">EXPERIENCE</div>

      <div class="container-xl c2-exp-inner">

        <div class="c2-exp-header" data-reveal>
          <span class="overline-light">crafted for you</span>
          <h2 class="c2-exp-h2">Curated<br />Experiences</h2>
        </div>

        <div class="c2-exp-list">
          {experiences.map((exp, i) => (
            <div class={`c2-exp-row ${i % 2 === 1 ? 'c2-exp-row--reverse' : ''}`} data-reveal data-delay={String(i * 80)}>
              <div class="c2-exp-img-wrap">
                <span class="c2-exp-num" aria-hidden="true">{exp.id}</span>
                <img
                  src={exp.img}
                  alt={exp.title}
                  class="c2-exp-img"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="c2-exp-text">
                <span class="c2-exp-tagline">{exp.tagline}</span>
                <h3 class="c2-exp-title">{exp.title}</h3>
                <div class="c2-exp-rule" aria-hidden="true"></div>
                <p class="c2-exp-desc">{exp.description}</p>
                <a href="/experiences" class="btn-luxury btn-luxury-light c2-exp-link">
                  Discover more
                  <svg width="12" height="9" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                    <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>

        <div class="c2-exp-footer" data-reveal>
          <a href="/experiences" class="btn-filled btn-filled-light">
            All Experiences
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
              <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
            </svg>
          </a>
        </div>

      </div>
    </section>


    <!-- ─── 5. ITINERARIES ───────────────────────────────────────────── -->
    <section class="layout-outer section-pad bg-cream" aria-label="Sample itineraries">
      <div class="container-xl">

        <div class="c2-itin-header" data-reveal>
          <span class="overline">tailored journeys</span>
          <h2 class="c2-itin-h2">Sample Itineraries</h2>
          <p class="c2-itin-intro">
            Starting points, not blueprints — every journey begins with your story.
          </p>
        </div>

        <div class="c2-itin-list">
          {itineraries.map((journey, i) => (
            <a
              href={journey.slug}
              class="c2-itin-row"
              data-reveal
              data-delay={String(i * 100)}
              aria-label={`View itinerary: ${journey.title}`}
            >
              <div class="c2-itin-img-wrap">
                <img
                  src={journey.img}
                  alt={journey.title}
                  class="c2-itin-img"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="c2-itin-content">
                <div class="c2-itin-meta">
                  <span class="c2-itin-id">{journey.id}</span>
                  <span class="c2-itin-meta-rule" aria-hidden="true"></span>
                  <span class="c2-itin-details">{journey.country} · {journey.nights}</span>
                </div>
                <h3 class="c2-itin-title">{journey.title}</h3>
                <p class="c2-itin-desc">{journey.description}</p>
                <ul class="c2-itin-highlights">
                  {journey.highlights.map((h) => (
                    <li class="c2-itin-highlight">
                      <span class="c2-itin-highlight-rule" aria-hidden="true"></span>
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
                <div class="c2-itin-cta">
                  <span class="btn-luxury c2-itin-btn">
                    View itinerary
                    <svg width="12" height="9" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                      <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
          <div class="c2-itin-list-border" aria-hidden="true"></div>
        </div>

        <div class="c2-view-all" data-reveal>
          <a href="/itineraries" class="btn-filled">
            All Itineraries
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
              <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
            </svg>
          </a>
        </div>

      </div>
    </section>


    <!-- ─── 6. ABOUT / WHY HALCYON ───────────────────────────────────── -->
    <section class="layout-outer section-pad c2-about-section" aria-label="About Halcyon">
      <div class="container-xl">
        <div class="c2-about-grid">

          <div class="c2-about-img-col" data-reveal="left">
            <img
              src="https://picsum.photos/seed/halcyon-about-nz-golden-c2/900/1100"
              alt="Golden hour light over Aotearoa New Zealand"
              class="c2-about-img"
              loading="lazy"
              decoding="async"
            />
            <div class="c2-about-label">
              <span class="c2-about-label-text">Est. 2010 · Aotearoa</span>
            </div>
          </div>

          <div class="c2-about-text" data-reveal="right" data-delay="120">
            <span class="overline">about halcyon</span>
            <h2 class="c2-about-h2">
              Travel as it was<br />meant to be
            </h2>
            <p class="c2-about-p">
              Halcyon was founded on one belief: that New Zealand and Australia hold some of the most extraordinary experiences on earth — and that most travellers barely scratch the surface. We're here to change that.
            </p>
            <p class="c2-about-p">
              Every journey is planned personally by us, drawing on deep local knowledge, trusted relationships, and an endless drive to find the moments that take your breath away.
            </p>

            <div class="c2-pillars">
              {pillars.map((pillar) => (
                <div class="c2-pillar">
                  <div class="c2-pillar-rule" aria-hidden="true"></div>
                  <h4 class="c2-pillar-title">{pillar.title}</h4>
                  <p class="c2-pillar-body">{pillar.body}</p>
                </div>
              ))}
            </div>

            <a href="/about" class="btn-luxury c2-about-link">
              Our story
              <svg width="12" height="9" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
              </svg>
            </a>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── 7. FEATURED TESTIMONIAL ─────────────────────────────────── -->
    <section class="layout-outer section-pad c2-quote-section" aria-label="Guest testimonial">
      <div class="c2-quote-wrap">

        <div class="c2-quote-mark" aria-hidden="true">"</div>

        <blockquote class="c2-quote-text" data-reveal>
          Halcyon showed us a New Zealand we never could have found ourselves. Every detail was considered, every moment felt personal. It was, without question, the finest journey of our lives.
        </blockquote>

        <div class="c2-quote-attr" data-reveal data-delay="120">
          <span class="c2-quote-attr-rule" aria-hidden="true"></span>
          <span class="c2-quote-name">Sarah & James Whitfield · London, UK</span>
          <span class="c2-quote-journey">South Island Grand Tour · 14 nights</span>
        </div>

      </div>
    </section>


    <!-- ─── 8. CTA SECTION ───────────────────────────────────────────── -->
    <section class="layout-outer c2-cta-section" aria-label="Begin your journey">
      <div class="c2-cta-inner">

        <img
          src="https://picsum.photos/seed/halcyon-cta-nz-landscape-c2/1920/900"
          alt="New Zealand landscape at golden hour"
          class="c2-cta-bg"
          loading="lazy"
          decoding="async"
        />

        <div class="c2-cta-overlay" aria-hidden="true"></div>

        <div class="c2-cta-content" data-reveal>
          <span class="overline-light c2-cta-overline">your journey awaits</span>
          <h2 class="c2-cta-h2">
            Let's Plan Something <em class="c2-cta-em">Extraordinary</em>
          </h2>
          <p class="c2-cta-sub">
            A conversation costs nothing. Tell us your dream and we'll show you what's possible.
          </p>
          <div class="c2-cta-btns">
            <a href="/contact" class="btn-filled btn-filled-light c2-cta-primary">
              Begin an Enquiry
            </a>
            <a href="/itineraries" class="btn-luxury btn-luxury-light c2-cta-secondary">
              Browse Itineraries
              <svg width="12" height="9" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
              </svg>
            </a>
          </div>
          <div class="c2-trust-bar" aria-label="Service commitments">
            <span class="c2-trust-item">Fully Private</span>
            <span class="c2-trust-sep" aria-hidden="true">·</span>
            <span class="c2-trust-item">No Obligation</span>
            <span class="c2-trust-sep" aria-hidden="true">·</span>
            <span class="c2-trust-item">Expert Guidance</span>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ═══════════════════════════════════════════════
     HERO
  ═══════════════════════════════════════════════ */
  .c2-hero-wrap {
    position: relative;
    height: 100svh;
    min-height: 620px;
    overflow: hidden;
    background: #112250;
  }

  .c2-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .c2-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(17, 34, 80, 0.28) 0%,
      rgba(0, 0, 0, 0.06) 38%,
      rgba(0, 0, 0, 0.62) 100%
    );
  }

  .c2-hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 clamp(20px, 5vw, 80px) clamp(60px, 10vh, 100px);
  }

  .c2-hero-overline {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }

  .c2-rule-h {
    display: block;
    width: 40px;
    height: 1px;
    background: rgba(245, 240, 233, 0.4);
  }

  .c2-dest-label {
    font-family: 'Cormorant Unicase', serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.38em;
    color: rgba(245, 240, 233, 0.7);
    text-transform: uppercase;
  }

  .c2-hero-h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(46px, 8vw, 112px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.015em;
    color: #f5f0e9;
    max-width: 1020px;
    margin: 0;
  }

  .c2-hero-divider {
    width: 60px;
    height: 1px;
    background: rgba(245, 240, 233, 0.3);
    margin: 32px auto;
  }

  .c2-hero-sub {
    font-family: 'Playfair Display', serif;
    font-size: clamp(15px, 1.5vw, 20px);
    font-style: italic;
    color: rgba(245, 240, 233, 0.72);
    max-width: 560px;
    line-height: 1.85;
    margin: 0;
  }

  .c2-hero-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 40px;
  }

  .c2-cta-primary {
    padding: 16px 40px !important;
    font-size: 11px !important;
    letter-spacing: 0.2em !important;
  }

  .c2-cta-secondary {
    font-size: 11px;
    letter-spacing: 0.18em;
  }

  .c2-hero-location {
    position: absolute;
    left: 28px;
    bottom: 44px;
  }

  .c2-location-text {
    font-family: 'Cormorant Unicase', serif;
    font-size: 9px;
    letter-spacing: 0.4em;
    color: rgba(245, 240, 233, 0.35);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    display: block;
  }

  /* ═══════════════════════════════════════════════
     BRAND STATEMENT
  ═══════════════════════════════════════════════ */
  .c2-statement-wrap {
    max-width: 860px;
    margin: 0 auto;
    text-align: center;
    padding: 0 clamp(20px, 5vw, 80px);
  }

  .c2-statement-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 40px;
  }

  .c2-statement-rule {
    display: block;
    width: 48px;
    height: 1px;
    background: rgba(17, 34, 80, 0.18);
  }

  .c2-statement-quote {
    font-family: 'Playfair Display', serif;
    font-size: clamp(22px, 3vw, 40px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.6;
    color: #112250;
    letter-spacing: 0.01em;
    margin: 0;
  }

  .c2-statement-sig {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-top: 40px;
  }

  .c2-statement-sig-rule {
    display: block;
    width: 1px;
    height: 40px;
    background: rgba(17, 34, 80, 0.16);
  }

  .c2-statement-sig-name {
    font-family: 'Cormorant Unicase', serif;
    font-size: 11px;
    letter-spacing: 0.28em;
    color: rgba(17, 34, 80, 0.4);
    text-transform: uppercase;
  }

  /* ═══════════════════════════════════════════════
     ACCOMMODATION
  ═══════════════════════════════════════════════ */
  .c2-accom-section {
    background: #fff;
  }

  .c2-section-header {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: clamp(40px, 6vw, 72px);
  }

