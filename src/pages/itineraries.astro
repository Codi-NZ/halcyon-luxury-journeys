---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const journeys = [
  // ─── New Zealand ────────────────────────────────────────
  {
    id:          '01',
    title:       'The South Island Grand Tour',
    subtitle:    'Alps, Fiordland & the Lodge Circuit',
    country:     'New Zealand',
    region:      'Queenstown · Fiordland · West Coast',
    duration:    '14 nights',
    season:      'Year-round · Peak: Oct – Apr',
    description: "An immersive odyssey through the South Island's most dramatic landscapes. Begin in Queenstown's alpine embrace, journey into the primal silence of Fiordland by private charter, and trace the West Coast's wild edge before descending into the vineyards of Central Otago. Every lodge is hand-selected. Every transition is private.",
    highlights: [
      'Private Milford Sound overnight cruise',
      'Helicopter landing on Franz Josef Glacier',
      'Blanket Bay and Fiordland Lodge circuit',
      'Exclusive cellar doors, Central Otago',
    ],
    image: 'https://picsum.photos/seed/south-island-grand-nz/960/640',
    imageAlt: 'Dramatic fjord landscape, Fiordland New Zealand',
  },
  {
    id:          '02',
    title:       'Northland & Bay of Islands',
    subtitle:    'Private Sail Through Aotearoa\'s Birthplace',
    country:     'New Zealand',
    region:      'Auckland · Bay of Islands · Cape Brett',
    duration:    '8 nights',
    season:      'Nov – Apr',
    description: "Sail the sapphire waters of Northland aboard a private vessel, discovering hidden coves, deserted beaches, and the seafaring history of modern New Zealand. Come ashore for a private Waitangi Treaty Grounds tour, dine on the verandah of a clifftop lodge, and watch the sun set over ninety miles of unbroken coastline.",
    highlights: [
      'Exclusive private yacht charter, full crew',
      'After-hours Waitangi Treaty Grounds visit',
      'Cape Brett Lighthouse overnight stay',
      'Private dining at Kauri Cliffs lodge',
    ],
    image: 'https://picsum.photos/seed/bay-of-islands-nz/960/640',
    imageAlt: 'Turquoise waters of the Bay of Islands, New Zealand',
  },
  {
    id:          '03',
    title:       'Te Waipounamu — West Coast Wilderness',
    subtitle:    'Glaciers, Rainforest & the Southern Alps',
    country:     'New Zealand',
    region:      'Franz Josef · Fox Glacier · Haast Pass',
    duration:    '10 nights',
    season:      'Sep – May',
    description: "Follow the edge of the world down New Zealand's wild west coast, where ancient glaciers descend into temperate rainforest and no road leads twice to the same place. This journey moves slowly, deliberately — through landscapes measured in millennia rather than miles, with guides who know their names.",
    highlights: [
      'Private helicopter glacier walks, Franz Josef & Fox',
      'Exclusive Wilderness Lodge Lake Moeraki stay',
      'Kayak through Cathedral Rocks sea caves',
      'Night sky immersion, Mackenzie Dark Sky Reserve',
    ],
    image: 'https://picsum.photos/seed/west-coast-wilderness-nz/960/640',
    imageAlt: 'West Coast rainforest and glacier, New Zealand',
  },
  {
    id:          '04',
    title:       "Hawke's Bay, Marlborough & Beyond",
    subtitle:    'New Zealand\'s Wine, Food & Art Country',
    country:     'New Zealand',
    region:      "Hawke's Bay · Marlborough · Nelson",
    duration:    '7 nights',
    season:      'Feb – May',
    description: "A considered journey through the sun-warmed east coast — from Hawke's Bay's art deco towns and estate cellar doors to the golden valleys of Marlborough, where Sauvignon Blanc was all but invented. Private chef dinners, boutique estate stays, and unhurried afternoons define every day.",
    highlights: [
      "Private estate tastings, Hawke's Bay",
      'Truffle hunt and private lunch, Gisborne',
      'Helicopter over the Marlborough Sounds',
      "Chef's table at The Farm at Cape Kidnappers",
    ],
    image: 'https://picsum.photos/seed/hawkes-bay-wine-nz/960/640',
    imageAlt: "Rolling vineyard hills, Hawke's Bay New Zealand",
  },
  // ─── Australia ──────────────────────────────────────────
  {
    id:          '05',
    title:       "Australia's Red Centre & the Reef",
    subtitle:    'From Ancient Earth to Living Ocean',
    country:     'Australia',
    region:      'Uluru · Alice Springs · Whitsundays',
    duration:    '12 nights',
    season:      'Apr – Sep',
    description: "A journey of contrasts that only Australia can offer — from the ancient ochre stillness of Uluru at first light to the luminous, living world beneath the Coral Sea. Between these poles lies a continent of stories. Private Indigenous guides carry them; you carry only the memory.",
    highlights: [
      'Sunrise at Uluru with private Indigenous guide',
      'Longitude 131° — tented pavilion stay',
      'Private reef dive, outer Whitsundays',
      'Helicopter over the Bungle Bungle Range',
    ],
    image: 'https://picsum.photos/seed/red-centre-reef-au/960/640',
    imageAlt: 'Uluru at golden hour, Northern Territory Australia',
  },
  {
    id:          '06',
    title:       'The Kimberley & Ningaloo Coast',
    subtitle:    'Western Australia\'s Last Great Wilderness',
    country:     'Australia',
    region:      'Broome · The Kimberley · Ningaloo Reef',
    duration:    '10 nights',
    season:      'May – Oct',
    description: "One of the planet's last truly wild places — ancient gorges that predate life on land, ochre coasts that meet a turquoise sea, and a coral reef where whale sharks gather like clockwork each March through July. Your private aircraft makes distance irrelevant. What remains is the encounter.",
    highlights: [
      'Private fixed-wing over the Kimberley gorges',
      'Cable Beach sunset by private camel train',
      'Swim with whale sharks, Ningaloo Reef',
      'Sal Salis — wilderness camp, beachfront pavilion',
    ],
    image: 'https://picsum.photos/seed/kimberley-ningaloo-au/960/640',
    imageAlt: 'The Kimberley coastline, Western Australia',
  },
  {
    id:          '07',
    title:       "Tasmania's Wild Edge",
    subtitle:    'Art, Wilderness & the World\'s End',
    country:     'Australia',
    region:      'Hobart · Freycinet · Bay of Fires',
    duration:    '8 nights',
    season:      'Oct – Apr',
    description: "An island apart — from one of the world's most provocative art museums to lodges perched above wilderness that has never been farmed. Tasmania moves at a pace all its own: unhurried, unspoiled, and surprising. The Bay of Fires burns amber every evening. You will not want to leave.",
    highlights: [
      'Private after-hours MONA tour with curator',
      'Pumphouse Point — overwater lodge, Lake St Clair',
      'Walk the Bay of Fires with private naturalist',
      "Freycinet Lodge — Wineglass Bay at dawn",
    ],
    image: 'https://picsum.photos/seed/tasmania-wild-au/960/640',
    imageAlt: 'Bay of Fires, orange lichen coastline, Tasmania',
  },
];
---

<Layout
  title="Signature Journeys — Halcyon Luxury Journeys"
  description="Seven curated journeys through New Zealand and Australia. Each one a masterwork — designed to inspire, built around you."
>
  <Header />

  <main>

    <!-- ── Page Hero ────────────────────────────────────── -->
    <section class="page-hero">
      <div class="hero-inner">

        <div class="hero-text">
          <p class="eyebrow" data-reveal>Signature Journeys</p>
          <h1 class="page-title" data-reveal data-delay="80">
            Curated for the<br/>endlessly curious.
          </h1>
          <p class="page-intro" data-reveal data-delay="180">
            Seven journeys across two extraordinary countries.
            Starting points, never blueprints — every one begins
            with your story.
          </p>
        </div>

        <!-- Journey index — desktop sidebar -->
        <nav class="hero-index" aria-label="Jump to journey" data-reveal="right" data-delay="300">
          {journeys.map((j) => (
            <a href={`#journey-${j.id}`} class="hero-index-link">
              <span class="hero-index-num">{j.id}</span>
              <span class="hero-index-title">{j.title}</span>
              <span class="hero-index-country">{j.country}</span>
            </a>
          ))}
        </nav>

      </div>
    </section>

    <!-- ── Philosophy strip ─────────────────────────────── -->
    <section class="philosophy">
      <div class="philosophy-inner">
        <div class="rule" style="margin-bottom: 40px;"></div>
        <blockquote class="philosophy-quote" data-reveal>
          "These are not packages. They are composed works — refined over years of access,
          shaped by ten thousand private moments, and presented to you as inspiration,
          not inventory. We will take any one of them and make it entirely, unmistakably yours."
        </blockquote>
        <div class="philosophy-meta" data-reveal data-delay="100">
          <span class="philosophy-count">7 journeys</span>
          <span class="philosophy-sep">·</span>
          <span class="philosophy-countries">New Zealand & Australia</span>
          <span class="philosophy-sep">·</span>
          <span class="philosophy-range">6 to 14 nights</span>
        </div>
      </div>
    </section>

    <!-- ── Journey Cards ─────────────────────────────────── -->
    <section class="journeys-section">
      <div class="journeys-inner">
        <div class="journeys-grid">

          {journeys.map((journey, i) => (
            <article
              id={`journey-${journey.id}`}
              class="jcard"
              data-reveal
              data-delay={String(i * 70)}
            >

              <!-- Image -->
              <div class="jcard-img-wrap">
                <img
                  src={journey.image}
                  alt={journey.imageAlt}
                  class="jcard-img"
                  loading="lazy"
                  decoding="async"
                />
                <!-- Hover overlay -->
                <div class="jcard-overlay" aria-hidden="true">
                  <a href="/enquire" class="jcard-overlay-link" tabindex="-1">
                    Begin planning
                    <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
                      <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
                    </svg>
                  </a>
                </div>
                <!-- Number badge -->
                <span class="jcard-num" aria-hidden="true">{journey.id}</span>
              </div>

              <!-- Card body -->
              <div class="jcard-body">

                <!-- Meta row -->
                <div class="jcard-meta">
                  <span class="jcard-country">{journey.country}</span>
                  <span class="jcard-dot" aria-hidden="true">·</span>
                  <span class="jcard-region">{journey.region}</span>
                  <span class="jcard-duration">{journey.duration}</span>
                </div>

                <!-- Title -->
                <h2 class="jcard-title">{journey.title}</h2>
                <p class="jcard-subtitle">{journey.subtitle}</p>

                <!-- Divider -->
                <div class="jcard-rule" aria-hidden="true"></div>

                <!-- Description -->
                <p class="jcard-desc">{journey.description}</p>

                <!-- Highlights -->
                <ul class="jcard-highlights" aria-label="Journey highlights">
                  {journey.highlights.map((h) => (
                    <li class="jcard-hl-item">
                      <span class="jcard-hl-dot" aria-hidden="true"></span>
                      <span class="jcard-hl-text">{h}</span>
                    </li>
                  ))}
                </ul>

                <!-- Footer: season + CTA -->
                <div class="jcard-footer">
                  <p class="jcard-season">
                    <span class="jcard-season-label">Best season</span>
                    {journey.season}
                  </p>
                  <a href="/enquire" class="btn-luxury jcard-cta">
                    Plan this journey
                    <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                      <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
                    </svg>
                  </a>
                </div>

              </div>
            </article>
          ))}

        </div>
      </div>
    </section>

    <!-- ── Bespoke CTA ───────────────────────────────────── -->
    <section class="bespoke-cta" data-reveal>
      <div class="bespoke-inner">

        <div class="bespoke-text-col">
          <p class="bespoke-eyebrow">Don't see your journey here?</p>
          <h2 class="bespoke-heading">
            The most memorable journeys<br/>
            are the ones we design together.
          </h2>
          <p class="bespoke-body">
            None of our signature journeys will ever be yours exactly as written.
            They are always a beginning. Tell us what calls to you — a landscape,
            a season, a feeling — and we will build something entirely new.
          </p>
          <div class="bespoke-actions">
            <a href="/enquire" class="btn-filled btn-filled-light">
              Start the conversation
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
              </svg>
            </a>
            <a href="/about" class="btn-luxury btn-luxury-light" style="margin-top: 4px;">
              How we work
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="bespoke-feature" aria-hidden="true">
          <!-- Decorative SVG — abstract NZ + AU map suggestion -->
          <svg viewBox="0 0 240 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="bespoke-map">
            <!-- NZ North Island outline -->
            <path d="M80 18 C84 14 90 12 96 15 C107 21 116 34 120 50 C124 64 126 72 134 85 C142 98 146 112 142 126 C138 140 130 150 122 158 C113 167 104 170 95 170 C84 170 73 163 64 151 C55 139 50 123 52 107 C54 91 62 77 64 62 C66 47 70 30 80 18 Z" stroke="rgba(201,169,110,0.18)" stroke-width="1.2"/>
            <!-- NZ South Island outline -->
            <path d="M96 196 C105 192 118 194 129 201 C140 208 148 221 149 235 C150 248 146 261 142 273 C138 283 131 292 127 303 C121 315 119 328 112 339 C105 349 94 356 83 356 C71 356 58 347 49 336 C40 325 35 310 35 295 C35 280 41 265 43 250 C45 235 41 220 45 206 C49 193 62 186 77 186 C86 186 93 188 96 196 Z" stroke="rgba(201,169,110,0.18)" stroke-width="1.2"/>
            <!-- AU continent outline — simplified -->
            <path d="M138 40 C150 36 166 38 180 46 C196 55 208 70 212 88 C218 108 212 126 210 142 C208 156 210 168 208 182 C206 198 198 212 192 224 C186 238 182 254 174 266 C166 278 154 284 142 284 C128 284 114 276 104 264 C94 252 88 236 88 220 C88 204 94 190 96 175 C98 160 94 144 96 128 C98 114 106 100 110 86 C116 68 124 52 138 40 Z" stroke="rgba(201,169,110,0.10)" stroke-width="1" stroke-dasharray="4 5" transform="translate(0, -10)"/>
          </svg>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>

<!-- ─────────────────────────────────────────────────────── -->
<style>

  /* ── Page Hero ── */
  .page-hero {
    background: #F5F0E9;
    padding: clamp(80px, 11vw, 150px) 0 clamp(60px, 8vw, 100px);
    border-bottom: 1px solid rgba(17, 34, 80, 0.08);
  }
  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(24px, 6vw, 100px);
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }

  .eyebrow {
    font-family: 'Cormorant Unicase', serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #C9A96E;
    margin-bottom: 24px;
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .eyebrow.revealed { opacity: 1; transform: translateY(0); }

  .page-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(40px, 5.5vw, 80px);
    font-weight: 400;
    line-height: 1.06;
    letter-spacing: -0.01em;
    color: #112250;
    margin-bottom: 28px;
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.7s ease 0.08s, transform 0.7s ease 0.08s;
  }
  .page-title.revealed { opacity: 1; transform: translateY(0); }

  .page-intro {
    font-family: 'Lato', sans-serif;
    font-size: clamp(15px, 1.2vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: rgba(17, 34, 80, 0.6);
    max-width: 460px;
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.7s ease 0.18s, transform 0.7s ease 0.18s;
  }
  .page-intro.revealed { opacity: 1; transform: translateY(0); }

  /* Journey index sidebar */
  .hero-index {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-top: 4px;
    border-left: 1px solid rgba(17, 34, 80, 0.1);
    padding-left: clamp(24px, 3vw, 40px);
    opacity: 0; transform: translateX(36px);
    transition: opacity 0.9s ease 0.3s, transform 0.9s ease 0.3s;
  }
  .hero-index.revealed { opacity: 1; transform: translateX(0); }

  .hero-index-link {
    display: grid;
    grid-template-columns: 28px 1fr;
    grid-template-rows: auto auto;
    column-gap: 10px;
    row-gap: 2px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(17, 34, 80, 0.06);
    text-decoration: none;
    transition: opacity 0.25s ease;
    opacity: 0.65;
  }
  .hero-index-link:last-child { border-bottom: none; }
  .hero-index-link:hover { opacity: 1; }

  .hero-index-num {
    font-family: 'Cormorant Unicase', serif;
    font-size: 10px;
    letter-spacing: 0.18em;
    color: #C9A96E;
    grid-row: 1 / 3;
    align-self: center;
    padding-top: 2px;
  }
  .hero-index-title {
    font-family: 'Playfair Display', serif;
    font-size: 13px;
    font-weight: 400;
    color: #112250;
    line-height: 1.3;
  }
  .hero-index-country {
    font-family: 'Lato', sans-serif;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: rgba(17, 34, 80, 0.38);
    text-transform: uppercase;
  }

  /* ── Philosophy ── */
  .philosophy {
    background: #F5F0E9;
    padding: clamp(56px, 7vw, 96px) 0;
    border-bottom: 1px solid rgba(17, 34, 80, 0.07);
  }
  .philosophy-inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 clamp(24px, 6vw, 60px);
  }
  .philosophy-quote {
    font-family: 'Playfair Display', serif;
    font-size: clamp(17px, 1.6vw, 23px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.7;
    color: rgba(17, 34, 80, 0.7);
    margin: 0 0 32px;
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .philosophy-quote.revealed { opacity: 1; transform: translateY(0); }

  .philosophy-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    opacity: 0; transform: translateY(12px);
    transition: opacity 0.7s ease 0.1s, transform 0.7s ease 0.1s;
  }
  .philosophy-meta.revealed { opacity: 1; transform: translateY(0); }

  .philosophy-count,
  .philosophy-countries,
  .philosophy-range {
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(17, 34, 80, 0.4);
  }
  .philosophy-count { color: #C9A96E; }
  .philosophy-sep {
    color: rgba(17, 34, 80, 0.18);
    font-size: 12px;
  }

  /* ── Journey Cards ── */
  .journeys-section {
    background: #F5F0E9;
    padding: clamp(56px, 8vw, 104px) 0;
  }
  .journeys-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(24px, 6vw, 100px);
  }
  .journeys-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(40px, 5vw, 64px) clamp(28px, 3.5vw, 52px);
  }

  /* ── Card ── */
  .jcard {
    background: #fff;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.8s ease, transform 0.8s ease,
                box-shadow 0.4s ease;
  }
  .jcard.revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .jcard:hover {
    box-shadow: 0 16px 56px rgba(17, 34, 80, 0.10);
  }

  /* Image */
  .jcard-img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    flex-shrink: 0;
  }
  .jcard-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .jcard:hover .jcard-img { transform: scale(1.05); }

  /* Image hover overlay */
  .jcard-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17,34,80,0.72) 0%, transparent 55%);
    display: flex;
    align-items: flex-end;
    padding: 24px 28px;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .jcard:hover .jcard-overlay { opacity: 1; }
  .jcard-overlay-link {
    font-family: 'Playfair Display', serif;
    font-size: 13px;
    font-style: italic;
    letter-spacing: 0.14em;
    color: #F5F0E9;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid rgba(245,240,233,0.4);
    padding-bottom: 3px;
    transform: translateY(6px);
    transition: gap 0.3s ease, transform 0.4s ease, border-color 0.3s ease;
  }
  .jcard:hover .jcard-overlay-link { transform: translateY(0); }
  .jcard-overlay-link:hover { gap: 16px; border-color: rgba(245,240,233,0.85); }

  /* Number badge on image */
  .jcard-num {
    position: absolute;
    top: 18px;
    right: 20px;
    font-family: 'Cormorant Unicase', serif;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.22em;
    color: rgba(245, 240, 233, 0.75);
    background: rgba(17, 34, 80, 0.45);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 5px 12px;
    line-height: 1;
  }

  /* Card body */
  .jcard-body {
    padding: clamp(22px, 2.5vw, 32px) clamp(22px, 2.5vw, 32px) clamp(24px, 2.5vw, 32px);
    display: flex;
    flex-direction: column;
    flex: 1;
    border-top: 3px solid #F5F0E9; /* subtle lift off image */
  }

  /* Meta row */
  .jcard-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px 10px;
    margin-bottom: 14px;
  }
  .jcard-country {
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #112250;
  }
  .jcard-dot {
    color: rgba(17, 34, 80, 0.25);
    font-size: 11px;
  }
  .jcard-region {
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    color: rgba(17, 34, 80, 0.55);
    letter-spacing: 0.03em;
    flex: 1;
    min-width: 0;
  }
  .jcard-duration {
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F5F0E9;
    background: #112250;
    padding: 4px 12px;
    line-height: 1;
    white-space: nowrap;
    margin-left: auto;
  }

  /* Title */
  .jcard-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(20px, 2vw, 28px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: 0.01em;
    color: #112250;
