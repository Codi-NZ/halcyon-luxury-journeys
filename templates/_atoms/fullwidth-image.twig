{% import 'macros/images' as imageMacros %}

{% set transform = transform ?? 'section' %}
{% set image = image ?? null %}
{% set caption = caption ?? null %}

{% if image %}
    <figure>
        <div class="overflow-hidden">
            {{
                imageMacros.imagerSrcset(
                    image,
                    'fullwidth-' ~ transform ~ '-contain',
                    {
                        classes: 'hidden md:block w-full h-full object-cover object-center'
                    }
                )
            }}

            {{
                imageMacros.imagerSrcset(
                    image,
                    'fullwidth-mobile',
                    {
                        classes: 'md:hidden w-full h-full object-cover object-center'
                    }
                )
            }}
        </div>

        {% if caption %}
            <figcaption style="font-family:'Lato',sans-serif; font-size:13px; font-style:italic; color:rgba(17,34,80,0.45); margin-top:12px; letter-spacing:0.02em;">
                {{ caption }}
            </figcaption>
        {% endif %}
    </figure>
{% endif %}
