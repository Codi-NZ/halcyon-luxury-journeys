{% set quote = quote ?? null %}
{% set citation = citation ?? null %}

<figure class="bg-grey-50 border border-grey-200 rounded-2xl p-8 text-grey-900">
    <blockquote class="blockquote">
        {{ quote|replace('"', '')|replace('“', '')|replace('”', '')|raw }}
    </blockquote>

    {% if citation|default %}
        <figcaption class="mt-4">
            <cite class="not-italic">- {{ citation }}</cite>
        </figcaption>
    {% endif %}
</figure>
