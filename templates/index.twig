{% extends 'layouts/base' %}

{# Override the banner block — homepage has no standard banner #}
{% block banner %}{% endblock %}

{# Ensure entry is available — covers direct template rendering without Craft routing #}
{% if entry is not defined or entry is null %}
    {% set entry = craft.entries.section('homepage').one() %}
{% endif %}

{% block content %}

    {# ── Loading screen ────────────────────────────────────────────── #}
    {% include '_organisms/homepage/loading-screen' %}

    {# ── Hero ──────────────────────────────────────────────────────── #}
    {% include '_organisms/homepage/hero' %}

    {# ── Brand Intro ───────────────────────────────────────────────── #}
    {% include '_organisms/homepage/brand-intro' %}

    {# ── Destinations Accordion ────────────────────────────────────── #}
    {% include '_organisms/homepage/destinations-accordion' %}

    {# ── Cinematic Video ───────────────────────────────────────────── #}
    {% include '_organisms/homepage/cinematic-video' %}

    {# ── Experiences Carousel ──────────────────────────────────────── #}
    {% include '_organisms/homepage/experiences-carousel' %}

    {# ── Signature Journeys ────────────────────────────────────────── #}
    {% include '_organisms/homepage/signature-journeys' %}

    {# ── Why Halcyon ───────────────────────────────────────────────── #}
    {% include '_organisms/homepage/why-halcyon' %}

    {# ── Destination Story ─────────────────────────────────────────── #}
    {% include '_organisms/homepage/destination-story' %}

    {# ── Testimonials ──────────────────────────────────────────────── #}
    {% include '_organisms/homepage/testimonials' %}

    {# ── CTA Section ───────────────────────────────────────────────── #}
    {% include '_organisms/homepage/cta-section' %}

{% endblock %}
