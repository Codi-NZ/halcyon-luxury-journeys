{% extends 'layouts/base' %}

{% block banner %}{% endblock %}

{% block content %}

{# ── Hero area (from Single entry) ──────────────────── #}
{% set eyebrow = entry is defined and entry ? entry.pageEyebrow ?? 'Signature Journeys' : 'Signature Journeys' %}
{% set pageHeading = entry is defined and entry ? entry.heading ?? 'Curated for the\nendlessly curious.' : 'Curated for the\nendlessly curious.' %}
{% set intro = entry is defined and entry ? entry.summary ?? 'Seven journeys across two extraordinary countries. Starting points, never blueprints — every one begins with your story.' : 'Seven journeys across two extraordinary countries. Starting points, never blueprints — every one begins with your story.' %}
{% set quote = entry is defined and entry ? entry.philosophyQuote ?? '' : '"These are not packages. They are composed works — refined over years of access, shaped by ten thousand private moments, and presented to you as inspiration, not inventory. We will take any one of them and make it entirely, unmistakably yours."' %}

{# ── Channel entries ────────────────────────────────── #}
{% set journeys = craft.entries.section('signatureJourneys').all() %}

<!-- Page Hero -->
<section class="page-hero">
    <div class="hero-inner">
        <div class="hero-text">
            <p class="eyebrow" data-reveal>{{ eyebrow }}</p>
            <h1 class="page-title" data-reveal data-delay="80">
                {{ pageHeading|nl2br }}
            </h1>
            <p class="page-intro" data-reveal data-delay="180">
                {{ intro }}
            </p>
        </div>

        {% if journeys|length %}
            {% set heroIndexLimit = 6 %}
            <nav class="hero-index" aria-label="Jump to journey" data-reveal="right" data-delay="300">
                {% for journey in journeys|slice(0, heroIndexLimit) %}
                    <a href="#journey-{{ '%02d'|format(loop.index) }}" class="hero-index-link">
                        <span class="hero-index-num">{{ '%02d'|format(loop.index) }}</span>
                        <span class="hero-index-title">{{ journey.title }}</span>
                        <span class="hero-index-country">{{ journey.journeyCountry ?? '' }}</span>
                    </a>
                {% endfor %}
                {% if journeys|length > heroIndexLimit %}
                    <a href="#journeys" class="hero-index-viewall">
                        <span class="hero-index-viewall-label">View all {{ journeys|length }} journeys</span>
                        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                            <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
                        </svg>
                    </a>
                {% endif %}
            </nav>
        {% endif %}
    </div>
</section>

<!-- Philosophy Strip -->
{% if quote %}
    <section class="philosophy">
        <div class="philosophy-inner">
            <div class="rule" style="margin-bottom: 40px;"></div>
            <blockquote class="philosophy-quote" data-reveal>
                {{ quote }}
            </blockquote>
            <div class="philosophy-meta" data-reveal data-delay="100">
                <span class="philosophy-count">{{ journeys|length }} journey{{ journeys|length != 1 ? 's' : '' }}</span>
                <span class="philosophy-sep">&middot;</span>
                <span class="philosophy-countries">New Zealand &amp; Australia</span>
            </div>
        </div>
    </section>
{% endif %}

<!-- Filter Bar + Journey Cards (Alpine component) -->
<div
    x-data="journeyFilters()"
    x-init="init()"
>

    <!-- Filter Bar -->
    <section class="filter-section" aria-label="Filter signature journeys">
        <div class="filter-inner">
            <div class="filter-controls">
                <div class="filter-group">
                    <span class="filter-group-label" id="journey-country-filter-label">Country</span>
                    <div class="filter-pills" role="group" aria-labelledby="journey-country-filter-label">
                        <button
                            class="filter-pill"
                            :class="{ 'is-active': country === 'all' }"
                            :aria-pressed="(country === 'all').toString()"
                            @click="setCountry('all')"
                        >All Countries</button>
                        <button
                            class="filter-pill"
                            :class="{ 'is-active': country === 'New Zealand' }"
                            :aria-pressed="(country === 'New Zealand').toString()"
                            @click="setCountry('New Zealand')"
                        >New Zealand</button>
                        <button
                            class="filter-pill"
                            :class="{ 'is-active': country === 'Australia' }"
                            :aria-pressed="(country === 'Australia').toString()"
                            @click="setCountry('Australia')"
                        >Australia</button>
                    </div>
                </div>
            </div>
            <p class="filter-count" aria-live="polite" aria-atomic="true">
                <span x-text="visibleCount" style="font-family:'Playfair Display',serif; font-size:18px; font-style:normal; color:#112250; line-height:1;"></span>
                <span class="filter-count-label">journeys</span>
            </p>
        </div>
    </section>

<!-- Journey Cards -->
<section class="journeys-section" id="journeys">
    <div class="journeys-inner">
        <div class="journeys-grid">
            {% for journey in journeys %}
                {% set image = journey.journeyImage.one() ?? null %}
                {% set num = '%02d'|format(loop.index) %}
                {% set countryLabel = journey.journeyCountry.label ?? '' %}

                <a
                    href="{{ journey.url }}"
                    id="journey-{{ num }}"
                    class="jcard"
                    data-country="{{ countryLabel }}"
                    data-reveal
                    data-delay="{{ loop.index0 * 70 }}"
                    x-show="matchCard('{{ countryLabel }}')"
                    x-transition:enter="transition ease-out duration-300"
                    x-transition:enter-start="opacity-0 translate-y-4"
                    x-transition:enter-end="opacity-100 translate-y-0"
                >
                    <div class="jcard-img-wrap">
                        {% if image %}
                            {% set transformHandle = 'cardLarge' %}
                            {% set transformedUrl = image.getUrl(transformHandle) %}
                            {% set imageUrl = transformedUrl ?: image.url %}
                            {% set imageWidth = transformedUrl ? image.getWidth(transformHandle) : image.width %}
                            {% set imageHeight = transformedUrl ? image.getHeight(transformHandle) : image.height %}
                            <img
                                src="{{ imageUrl }}"
                                alt="{{ image.alt ?? image.title ?? journey.title }}"
                                class="jcard-img"
                                loading="lazy"
                                decoding="async"
                                width="{{ imageWidth }}"
                                height="{{ imageHeight }}"
                            />
                        {% endif %}
                        <span class="jcard-num" aria-hidden="true">{{ num }}</span>
                    </div>

                    <div class="jcard-body">
                        <div class="jcard-meta">
                            {% if journey.journeyCountry %}
                                <span class="jcard-country">{{ journey.journeyCountry }}</span>
                            {% endif %}
                            {% if journey.journeyRegion %}
                                <span class="jcard-sep" aria-hidden="true">&middot;</span>
                                <span class="jcard-region">{{ journey.journeyRegion }}</span>
                            {% endif %}
                            {% if journey.journeyDuration %}
                                <span class="jcard-duration">{{ journey.journeyDuration }}</span>
                            {% endif %}
                        </div>

                        <h3 class="jcard-title">{{ journey.title }}</h3>

                        {% if journey.journeySubtitle %}
                            <p class="jcard-subtitle">{{ journey.journeySubtitle }}</p>
                        {% endif %}

                        <div class="jcard-rule"></div>

                        {% if journey.journeyDescription %}
                            <p class="jcard-desc">{{ journey.journeyDescription }}</p>
                        {% endif %}

                        {% set highlights = journey.journeyHighlights.all() ?? [] %}
                        {% if highlights|length %}
                            <ul class="jcard-highlights">
                                {% for h in highlights %}
                                    <li class="jcard-highlight">{{ h.highlightText }}</li>
                                {% endfor %}
                            </ul>
                        {% endif %}

                        <div class="jcard-footer">
                            {% if journey.journeySeason %}
                                <div class="jcard-season">
                                    <span class="jcard-season-label">Best season</span>
                                    <span class="jcard-season-value">{{ journey.journeySeason }}</span>
                                </div>
                            {% endif %}
                            <span class="btn-luxury">
                                View More
                                <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                                    <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
                                </svg>
                            </span>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>

        <!-- Empty state -->
        <div class="dest-empty" x-show="visibleCount === 0" x-cloak>
            <div class="rule" style="margin: 0 auto 28px;"></div>
            <p class="dest-empty-msg">No journeys match your current filter.</p>
            <button class="dest-reset-btn btn-luxury" @click="resetFilters()">
                Clear filter
                <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                    <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
                </svg>
            </button>
        </div>
    </div>
</section>

</div>

<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('journeyFilters', () => ({
        country: 'all',
        cards: {{ journeys|map(j => { country: j.journeyCountry.label ?? '' })|json_encode|raw }},

        get visibleCount() {
            return this.cards.filter(c => this.matchCard(c.country)).length;
        },

        init() {
            const params = new URLSearchParams(window.location.search);
            this.country = params.get('country') || 'all';
        },

        setCountry(value) {
            this.country = value;
            this.syncUrl();
            this.scrollToGrid();
        },

        scrollToGrid() {
            this.$nextTick(() => {
                const grid = document.querySelector('.journeys-section');
                if (grid) {
                    grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        },

        resetFilters() {
            this.country = 'all';
            this.syncUrl();
        },

        matchCard(cardCountry) {
            if (this.country === 'all') return true;
            if (cardCountry === this.country) return true;
            if (cardCountry === 'Australia and New Zealand') return true;
            return false;
        },

        syncUrl() {
            const params = new URLSearchParams();
            if (this.country !== 'all') params.set('country', this.country);
            const qs = params.toString();
            const url = window.location.pathname + (qs ? '?' + qs : '');
            window.history.replaceState({}, '', url);
        }
    }));
});
</script>

<!-- Bespoke CTA -->
<section class="plan-cta" data-reveal>
    <div class="plan-cta-inner">
        <div class="rule" style="margin-bottom: 32px;"></div>
        <p class="plan-cta-eyebrow">Don't see your journey here?</p>
        <h2 class="plan-cta-heading">The most memorable journeys are the ones we design together.</h2>
        <p class="plan-cta-body">
            These seven are starting points. Tell us your story and we'll compose something entirely new.
        </p>
        <a href="/contact" class="btn-filled btn-filled-light">
            Begin a Conversation
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
            </svg>
        </a>
    </div>
</section>

{% endblock %}
