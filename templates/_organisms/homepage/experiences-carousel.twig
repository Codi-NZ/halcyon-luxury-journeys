{#
  Experiences Carousel — draggable card carousel with hover overlays.
  Expects: entry.experiencesHeading, entry.experiencesCopy,
           entry.experiencesCarouselInspirations (optional Entries field, max 6, Inspiration section).

  If no inspirations are selected, the six most recent Inspiration articles are shown.
  If one or more are selected, those entries are used in selection order (still capped at 6 by the field).
#}

{% set sectionHeading = entry.experiencesHeading ?? 'The Art of Extraordinary' %}
{% set sectionCopy    = entry.experiencesCopy    ?? 'From superyachts to secret cellars, every experience we arrange is private, considered, and entirely yours.' %}

{% set pickedInspirations = entry.experiencesCarouselInspirations ?? null
    ? entry.experiencesCarouselInspirations.all()
    : [] %}
{% set experienceEntries = pickedInspirations|length
    ? pickedInspirations
    : craft.entries.section('inspiration').orderBy('postDate desc').limit(6).all() %}

<section style="background:#F5F0E9; padding:clamp(64px,8vw,120px) 0; overflow:hidden;">

    {# Header #}
    <div class="container-xl" style="margin-bottom:clamp(40px,4.5vw,64px);">
        <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:24px; flex-wrap:wrap;">
            <div>
                <div class="overline" style="margin-bottom:16px;" data-reveal>curated for you</div>
                <h2
                    class="display text-navy"
                    style="font-size:clamp(32px,3.5vw,52px); line-height:1.05; letter-spacing:0.02em;"
                    data-reveal data-delay="100"
                >
                    {{ sectionHeading|nl2br }}
                </h2>
            </div>
            <p
                class="type-body-font"
                style="font-size:clamp(14px,1vw,16px); line-height:1.8; color:rgba(17,34,80,0.6); max-width:380px; font-style:italic;"
                data-reveal="right" data-delay="150"
            >
                {{ sectionCopy }}
            </p>
        </div>
    </div>

    {# Carousel — same width as header (container-xl) so it stays centered on wide screens #}
    <div class="container-xl exp-carousel-shell" style="position:relative;">

        <button id="exp-prev" class="exp-arrow" type="button" aria-label="Previous" style="left:clamp(4px,1vw,16px);">
            <svg class="exp-arrow-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" aria-hidden="true">
                <path fill="currentColor" d="M201.4 297.4C188.9 309.9 188.9 330.2 201.4 342.7L361.4 502.7C373.9 515.2 394.2 515.2 406.7 502.7C419.2 490.2 419.2 469.9 406.7 457.4L269.3 320L406.6 182.6C419.1 170.1 419.1 149.8 406.6 137.3C394.1 124.8 373.8 124.8 361.3 137.3L201.3 297.3z"/>
            </svg>
        </button>

        <button id="exp-next" class="exp-arrow" type="button" aria-label="Next" style="right:clamp(4px,1vw,16px);">
            <svg class="exp-arrow-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" aria-hidden="true">
                <path fill="currentColor" d="M439.1 297.4C451.6 309.9 451.6 330.2 439.1 342.7L279.1 502.7C266.6 515.2 246.3 515.2 233.8 502.7C221.3 490.2 221.3 469.9 233.8 457.4L371.2 320L233.9 182.6C221.4 170.1 221.4 149.8 233.9 137.3C246.4 124.8 266.7 124.8 279.2 137.3L439.2 297.3z"/>
            </svg>
        </button>

        <div id="exp-track"
             class="exp-track"
             style="display:flex; gap:clamp(8px,1vw,14px); overflow-x:auto; scrollbar-width:none; padding:0 clamp(8px,2vw,24px); cursor:grab;">
            {% for article in experienceEntries %}
                {% set cardImage = article.image.one() ?? null %}
                {% set tagline = article.summary ?? '' %}
                {% set taglinePlain = tagline|striptags|trim %}
                {% set taglineShort = taglinePlain ? taglinePlain|truncate(120, '…') : '' %}
                <a href="{{ article.url }}" class="exp-card" tabindex="0">
                    {% if cardImage %}
                        {% set transformed = cardImage.setTransform('cardMedium') %}
                        <img
                            src="{{ transformed.url }}"
                            alt="{{ cardImage.alt ?? cardImage.title ?? article.title }}"
                            class="exp-img"
                            loading="lazy"
                            width="{{ transformed.width }}"
                            height="{{ transformed.height }}"
                        />
                    {% else %}
                        <div class="exp-img" style="background:rgba(17,34,80,0.12);" role="img" aria-label=""></div>
                    {% endif %}
                    <div class="exp-overlay">
                        <div class="exp-overlay-inner">
                            <span class="exp-overlay-top-rule"></span>
                            <h3 class="exp-overlay-title">{{ article.title }}</h3>
                            <div class="exp-overlay-rule"></div>
                            {% if taglineShort %}
                                <p class="exp-overlay-tagline">{{ taglineShort }}</p>
                            {% endif %}
                            <span class="exp-overlay-cta">
                                Explore More
                                <svg width="12" height="8" viewBox="0 0 14 10" fill="none" style="margin-left:6px;" aria-hidden="true">
                                    <path d="M9 1l4 4-4 4M13 5H1" stroke="#F5F0E9" stroke-width="1.2"/>
                                </svg>
                            </span>
                        </div>
                    </div>
                </a>
            {% else %}
                <p class="type-body-font" style="padding:0 clamp(20px,5vw,80px); color:rgba(17,34,80,0.45); font-style:italic;">
                    No inspiration articles yet. Publish stories in the Inspiration section or pick them in the homepage Experiences Carousel field.
                </p>
            {% endfor %}
        </div>

    </div>
</section>

<script>
(function() {
    document.addEventListener('DOMContentLoaded', function() {
        var track   = document.getElementById('exp-track');
        var prevBtn = document.getElementById('exp-prev');
        var nextBtn = document.getElementById('exp-next');
        if (!track || !prevBtn || !nextBtn) return;

        var origCards = Array.from(track.querySelectorAll('.exp-card'));
        if (!origCards.length) return;

        var gap = function() { return parseFloat(getComputedStyle(track).gap) || 12; };
        var cardW = function() { return origCards[0].offsetWidth + gap(); };

        var clonesEnd   = origCards.map(function(c) { var cl = c.cloneNode(true); cl.setAttribute('aria-hidden','true'); return cl; });
        var clonesStart = origCards.map(function(c) { var cl = c.cloneNode(true); cl.setAttribute('aria-hidden','true'); return cl; });

        clonesEnd.forEach(function(c) { track.appendChild(c); });
        clonesStart.reverse().forEach(function(c) { track.insertBefore(c, track.firstChild); });

        track.scrollLeft = cardW() * origCards.length;

        track.addEventListener('scroll', function() {
            var total = cardW() * origCards.length;
            if (track.scrollLeft >= total * 2) { track.scrollLeft -= total; }
            else if (track.scrollLeft <= 0)    { track.scrollLeft += total; }
        }, { passive: true });

        nextBtn.addEventListener('click', function() { track.scrollBy({ left: cardW(), behavior: 'smooth' }); });
        prevBtn.addEventListener('click', function() { track.scrollBy({ left: -cardW(), behavior: 'smooth' }); });

        var isDown = false, startX = 0, scrollLeft = 0;
        track.addEventListener('mousedown', function(e) {
            isDown = true;
            track.classList.add('is-dragging');
            startX = e.pageX - track.offsetLeft;
            scrollLeft = track.scrollLeft;
        });
        document.addEventListener('mouseup', function() { isDown = false; track.classList.remove('is-dragging'); });
        track.addEventListener('mousemove', function(e) {
            if (!isDown) return;
            e.preventDefault();
            track.scrollLeft = scrollLeft - (e.pageX - track.offsetLeft - startX) * 1.5;
        });
    });
})();
</script>
