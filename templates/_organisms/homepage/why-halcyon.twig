{#
  Why Halcyon — cream background, four pillar cards with SVG icons.
  Expects: entry.whyHalcyonHeading
  The four pillars are static content (brand values, not editorial).
#}

{% set heading = entry.whyHalcyonHeading ?? 'Travel as it Was Meant to Be' %}

{% set pillars = [
    {
        title: 'Completely Private',
        body: 'Your journey belongs only to you. No shared itineraries, no compromise on preference.',
        icon: '<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="18" cy="20" r="8" stroke="#112250" stroke-width="1.2"/><circle cx="18" cy="20" r="3.5" stroke="#112250" stroke-width="1" opacity="0.4"/><line x1="24.5" y1="20" x2="38" y2="20" stroke="#112250" stroke-width="1.2" stroke-linecap="round"/><line x1="34" y1="20" x2="34" y2="24" stroke="#112250" stroke-width="1.2" stroke-linecap="round"/><line x1="38" y1="20" x2="38" y2="24" stroke="#112250" stroke-width="1.2" stroke-linecap="round"/></svg>',
    },
    {
        title: 'Insider Access',
        body: 'Deep relationships with lodges, guides, and operators unlock experiences beyond public reach.',
        icon: '<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="24" cy="24" r="18" stroke="#112250" stroke-width="1.2"/><circle cx="24" cy="24" r="3" fill="#112250" opacity="0.25"/><polygon points="24,6 26.5,21 24,18 21.5,21" fill="#112250" opacity="0.9"/><polygon points="24,42 21.5,27 24,30 26.5,27" fill="#112250" opacity="0.3"/><polygon points="6,24 21,21.5 18,24 21,26.5" fill="#112250" opacity="0.3"/><polygon points="42,24 27,26.5 30,24 27,21.5" fill="#112250" opacity="0.3"/><line x1="24" y1="8" x2="24" y2="11" stroke="#112250" stroke-width="1" opacity="0.2"/><line x1="24" y1="37" x2="24" y2="40" stroke="#112250" stroke-width="1" opacity="0.2"/><line x1="8" y1="24" x2="11" y2="24" stroke="#112250" stroke-width="1" opacity="0.2"/><line x1="37" y1="24" x2="40" y2="24" stroke="#112250" stroke-width="1" opacity="0.2"/></svg>',
    },
    {
        title: 'Exceptional Quality',
        body: 'Every lodge, transfer, and experience is handpicked against the highest standards of luxury.',
        icon: '<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><polygon points="24,5 40,20 24,43 8,20" stroke="#112250" stroke-width="1.2" fill="none"/><polygon points="24,5 40,20 24,43 8,20" stroke="#112250" stroke-width="0.5" fill="#112250" opacity="0.04"/><line x1="8" y1="20" x2="40" y2="20" stroke="#112250" stroke-width="0.8" opacity="0.25"/><line x1="24" y1="5" x2="24" y2="20" stroke="#112250" stroke-width="0.8" opacity="0.2"/></svg>',
    },
    {
        title: 'End-to-End Care',
        body: 'From first enquiry to final farewell, our team is available every step of the journey.',
        icon: '<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M8 36 C 8 36, 16 12, 24 20 S 36 8 40 12" stroke="#112250" stroke-width="1.2" stroke-linecap="round" fill="none" opacity="0.35"/><circle cx="8" cy="36" r="3.5" stroke="#112250" stroke-width="1.2"/><circle cx="24" cy="20" r="2.5" stroke="#112250" stroke-width="1" fill="#112250" opacity="0.2"/><circle cx="40" cy="12" r="3.5" stroke="#112250" stroke-width="1.2" fill="#112250" opacity="0.15"/><circle cx="40" cy="12" r="1.5" fill="#112250" opacity="0.5"/></svg>',
    },
] %}

<section class="section-pad" style="background:#F5F0E9; position:relative;">
    <div class="container-xl">

        <div style="display:flex; flex-direction:column; align-items:center; text-align:center; margin-bottom:clamp(48px,6vw,80px);">
            <div class="overline" style="margin-bottom:24px;" data-reveal>why halcyon</div>
            <h2
                class="display text-navy"
                style="font-size:clamp(40px,5.5vw,80px); line-height:1.05; max-width:700px;"
                data-reveal data-delay="100"
            >
                {{ heading }}
            </h2>
            <div style="width:1px; height:48px; background:rgba(17,34,80,0.15); margin-top:32px;" data-reveal data-delay="200"></div>
        </div>

        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px,1fr)); gap:clamp(32px,4vw,40px);">
            {% for pillar in pillars %}
                <div
                    style="display:flex; flex-direction:column; align-items:center; text-align:center;"
                    data-reveal
                    data-delay="{{ loop.index0 * 120 }}"
                >
                    <div style="margin-bottom:28px;">{{ pillar.icon|raw }}</div>
                    <div style="width:36px; height:1px; background:rgba(17,34,80,0.2); margin-bottom:24px;"></div>
                    <h3 class="text-navy type-heading-font"
                        style="font-size:22px; font-weight:400; letter-spacing:0.08em; margin-bottom:14px; line-height:1.3;">
                        {{ pillar.title }}
                    </h3>
                    <p class="type-body-font"
                       style="font-size:14.5px; font-style:italic; color:rgba(17,34,80,0.6); line-height:1.9;">
                        {{ pillar.body }}
                    </p>
                </div>
            {% endfor %}
        </div>

    </div>
</section>
