{#
  Why Halcyon — cream background, pillar cards with SVG icons.
  Expects: entry.whyHalcyonOverline, entry.whyHalcyonHeading, entry.whyHalcyonPillars (Matrix)
  Each pillar entry has: title, whyHalcyonPillarBody, whyHalcyonPillarIcon (Dropdown)
#}

{% set overline = entry.whyHalcyonOverline ?? 'why halcyon' %}
{% set heading = entry.whyHalcyonHeading ?? 'Travel as it Was Meant to Be' %}

{# Icon SVG map — keyed by dropdown value #}
{% set iconMap = {
    'key': '<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="18" cy="20" r="8" stroke="#112250" stroke-width="1.2"/><circle cx="18" cy="20" r="3.5" stroke="#112250" stroke-width="1" opacity="0.4"/><line x1="24.5" y1="20" x2="38" y2="20" stroke="#112250" stroke-width="1.2" stroke-linecap="round"/><line x1="34" y1="20" x2="34" y2="24" stroke="#112250" stroke-width="1.2" stroke-linecap="round"/><line x1="38" y1="20" x2="38" y2="24" stroke="#112250" stroke-width="1.2" stroke-linecap="round"/></svg>',
    'compass': '<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="18" stroke="#112250" stroke-width="1.2"/><circle cx="24" cy="24" r="3" fill="#112250" opacity="0.25"/><polygon points="24,6 26.5,21 24,18 21.5,21" fill="#112250" opacity="0.9"/><polygon points="24,42 21.5,27 24,30 26.5,27" fill="#112250" opacity="0.3"/><polygon points="6,24 21,21.5 18,24 21,26.5" fill="#112250" opacity="0.3"/><polygon points="42,24 27,26.5 30,24 27,21.5" fill="#112250" opacity="0.3"/></svg>',
    'diamond': '<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><polygon points="24,5 40,20 24,43 8,20" stroke="#112250" stroke-width="1.2" fill="none"/><polygon points="24,5 40,20 24,43 8,20" stroke="#112250" stroke-width="0.5" fill="#112250" opacity="0.04"/><line x1="8" y1="20" x2="40" y2="20" stroke="#112250" stroke-width="0.8" opacity="0.25"/><line x1="24" y1="5" x2="24" y2="20" stroke="#112250" stroke-width="0.8" opacity="0.2"/></svg>',
    'path': '<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M8 36 C 8 36, 16 12, 24 20 S 36 8 40 12" stroke="#112250" stroke-width="1.2" stroke-linecap="round" fill="none" opacity="0.35"/><circle cx="8" cy="36" r="3.5" stroke="#112250" stroke-width="1.2"/><circle cx="24" cy="20" r="2.5" stroke="#112250" stroke-width="1" fill="#112250" opacity="0.2"/><circle cx="40" cy="12" r="3.5" stroke="#112250" stroke-width="1.2" fill="#112250" opacity="0.15"/><circle cx="40" cy="12" r="1.5" fill="#112250" opacity="0.5"/></svg>',
    'shield': '<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M24 4L8 12v12c0 10.5 6.8 20.3 16 24 9.2-3.7 16-13.5 16-24V12L24 4Z" stroke="#112250" stroke-width="1.2" fill="none"/><path d="M20 24l4 4 8-10" stroke="#112250" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/></svg>',
    'heart': '<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M24 40S6 28 6 18a9 9 0 0 1 18 0 9 9 0 0 1 18 0c0 10-18 22-18 22Z" stroke="#112250" stroke-width="1.2" fill="none"/><path d="M24 40S6 28 6 18a9 9 0 0 1 18 0 9 9 0 0 1 18 0c0 10-18 22-18 22Z" fill="#112250" opacity="0.04"/></svg>',
    'globe': '<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="18" stroke="#112250" stroke-width="1.2"/><ellipse cx="24" cy="24" rx="9" ry="18" stroke="#112250" stroke-width="0.8" opacity="0.4"/><line x1="6" y1="24" x2="42" y2="24" stroke="#112250" stroke-width="0.8" opacity="0.3"/><line x1="24" y1="6" x2="24" y2="42" stroke="#112250" stroke-width="0.8" opacity="0.15"/><path d="M8 16h32M8 32h32" stroke="#112250" stroke-width="0.6" opacity="0.2"/></svg>',
    'star': '<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><polygon points="24,4 29,18 44,18 32,28 36,42 24,34 12,42 16,28 4,18 19,18" stroke="#112250" stroke-width="1.2" fill="none"/><polygon points="24,4 29,18 44,18 32,28 36,42 24,34 12,42 16,28 4,18 19,18" fill="#112250" opacity="0.04"/></svg>',
} %}

{# Default icon order for fallback #}
{% set defaultIconKeys = ['key', 'compass', 'diamond', 'path'] %}

{# CMS pillars or fallback defaults #}
{% set cmsPillars = entry.whyHalcyonPillars is defined ? entry.whyHalcyonPillars.all() : [] %}

{% set defaultPillars = [
    { title: 'Completely Private', body: 'Your journey belongs only to you. No shared itineraries, no compromise on preference.', icon: 'key' },
    { title: 'Insider Access', body: 'Deep relationships with lodges, guides, and operators unlock experiences beyond public reach.', icon: 'compass' },
    { title: 'Exceptional Quality', body: 'Every lodge, transfer, and experience is handpicked against the highest standards of luxury.', icon: 'diamond' },
    { title: 'End-to-End Care', body: 'From first enquiry to final farewell, our team is available every step of the journey.', icon: 'path' },
] %}

{% set useCms = cmsPillars|length > 0 %}

<section class="section-pad" style="background:#F5F0E9; position:relative;">
    <div class="container-xl">

        <div style="display:flex; flex-direction:column; align-items:center; text-align:center; margin-bottom:clamp(48px,6vw,80px);">
            <div class="overline" style="margin-bottom:24px;" data-reveal>{{ overline }}</div>
            <h2
                class="display text-navy"
                style="font-size:clamp(40px,5.5vw,80px); line-height:1.05; max-width:700px;"
                data-reveal data-delay="100"
            >
                {{ heading }}
            </h2>
            <div style="width:1px; height:48px; background:rgba(17,34,80,0.15); margin-top:32px;" data-reveal data-delay="200"></div>
        </div>

        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px,1fr)); gap:clamp(32px,4vw,40px);">
            {% if useCms %}
                {% for pillar in cmsPillars %}
                    {% set iconKey = pillar.whyHalcyonPillarIcon.value ?? (defaultIconKeys[loop.index0] ?? 'key') %}
                    {% set icon = iconMap[iconKey] ?? iconMap['key'] %}

                    <div
                        style="display:flex; flex-direction:column; align-items:center; text-align:center;"
                        data-reveal
                        data-delay="{{ loop.index0 * 120 }}"
                    >
                        <div style="margin-bottom:28px; width:48px; height:48px;">{{ icon|raw }}</div>
                        <div style="width:36px; height:1px; background:rgba(17,34,80,0.2); margin-bottom:24px;"></div>
                        <h3 class="text-navy type-heading-font"
                            style="font-size:22px; font-weight:400; letter-spacing:0.08em; margin-bottom:14px; line-height:1.3;">
                            {{ pillar.title }}
                        </h3>
                        <p class="type-body-font"
                           style="font-size:14.5px; font-style:italic; color:rgba(17,34,80,0.6); line-height:1.9;">
                            {{ pillar.whyHalcyonPillarBody }}
                        </p>
                    </div>
                {% endfor %}
            {% else %}
                {% for pillar in defaultPillars %}
                    {% set icon = iconMap[pillar.icon] %}

                    <div
                        style="display:flex; flex-direction:column; align-items:center; text-align:center;"
                        data-reveal
                        data-delay="{{ loop.index0 * 120 }}"
                    >
                        <div style="margin-bottom:28px; width:48px; height:48px;">{{ icon|raw }}</div>
                        <div style="width:36px; height:1px; background:rgba(17,34,80,0.2); margin-bottom:24px;"></div>
                        <h3 class="text-navy type-heading-font"
                            style="font-size:22px; font-weight:400; letter-spacing:0.08em; margin-bottom:14px; line-height:1.3;">
                            {{ pillar.title }}
                        </h3>
                        <p class="type-body-font"
                           style="font-size:14.5px; font-style:italic; color:rgba(17,34,80,0.6); line-height:1.9;">
                            {{ pillar.body }}
                        </p>
                    </div>
                {% endfor %}
            {% endif %}
        </div>

    </div>
</section>
