{# Loading screen — first homepage visit in this tab only (sessionStorage). #}
<script>
(function () {
    try {
        if (sessionStorage.getItem('halcyonHomeLoaderSeen') === '1') {
            document.documentElement.classList.add('home-loader-skip');
        }
    } catch (e) {}
})();
</script>
<style>
    html.home-loader-skip #loading-screen {
        display: none !important;
        visibility: hidden;
        pointer-events: none;
    }
</style>
<div id="loading-screen" aria-hidden="true" role="presentation">
    <div style="display:flex; flex-direction:column; align-items:center; gap:0;">
        <div class="loading-bar-wrap">
            <div class="loading-bar"></div>
        </div>
        <img src="/halcyon-logo.svg" alt="" class="loading-logo" />
    </div>
</div>

<script>
(function () {
    window.addEventListener('load', function () {
        var screen = document.getElementById('loading-screen');
        if (!screen) return;

        if (document.documentElement.classList.contains('home-loader-skip')) {
            screen.style.display = 'none';
            return;
        }

        setTimeout(function () {
            screen.classList.add('exit');
            setTimeout(function () {
                screen.style.display = 'none';
                try {
                    sessionStorage.setItem('halcyonHomeLoaderSeen', '1');
                } catch (e) {}
            }, 1100);
        }, 1800);
    });
})();
</script>
