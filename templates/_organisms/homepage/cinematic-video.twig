{#
  Cinematic Video — full-width video block between accordion and carousel.
  Expects: entry.cinematicVideoUrl
#}

{% set videoUrl = entry.cinematicVideoUrl ?? '/207717_medium.mp4' %}

<section class="layout-outer" style="background:#F5F0E9;">
    <video
        style="display:block; height:min(72vh,760px); width:100%; object-fit:cover;"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-label="Luxury travel cinematic video"
    >
        <source src="{{ videoUrl }}" type="video/mp4" />
    </video>
</section>
