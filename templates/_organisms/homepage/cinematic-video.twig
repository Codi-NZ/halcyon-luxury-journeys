{#
  Cinematic Video — full-width video block between accordion and carousel.
  Expects: entry.cinematicVideoUrl (Assets field — supports direct video files or embedded assets via JSON)
#}

{% set cinematicAsset = entry.cinematicVideoUrl.one() ?? null %}

{% if cinematicAsset %}
    {% set embeddedVideo = craft.embeddedAssets.get(cinematicAsset) ?? null %}

    {% if embeddedVideo %}
        {# Embedded video (YouTube / Vimeo via JSON) — full width, cropped to cover #}
        <div class="cinematic-video-wrap">
            {{ embeddedVideo.getIFrameCode(['background=1', 'autoplay=1', 'muted=1', 'loop=1', 'autopause=0'])|raw }}
        </div>
    {% elseif cinematicAsset.kind == 'video' %}
        {# Direct video file (MP4) #}
        <video
            class="cinematic-video-native"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            aria-label="Luxury travel cinematic video"
        >
            <source src="{{ cinematicAsset.url }}" type="{{ cinematicAsset.mimeType }}" />
        </video>
    {% endif %}
{% endif %}
