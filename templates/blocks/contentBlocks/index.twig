{% set blocks = blocks ?? (entry.contentBlocks is defined ? entry.contentBlocks.with(craft.app.config.custom.eager.sectionBlocks).all() : null) %}
{% set modifiers = modifiers|default ? ' ' ~ modifiers %}

{% for block in blocks %}
    {% set nextBlock = loop.index < (blocks|length) ? blocks[loop.index] : null %}

    <div
        class="section-block section-block--{{ block.type.handle }}{{ nextBlock ? ' next--' ~ nextBlock.type.handle }}{{
        modifiers
        }}"
    >
        <div class="section-block__content">
            {% include ['/blocks/contentBlocks/' ~ block.type.handle, '/blocks/_missing'] ignore missing with {
                block: block,
                blockIndex: loop.index
            } %}
        </div>
    </div>
{% endfor %}
