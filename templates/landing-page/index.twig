<!doctype html>
<html lang="{{ currentSite.language }}" id="html">

<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<meta name="referrer" content="origin-when-cross-origin">

		{% if not craft.vite.devServerRunning() %}
			{{ craft.vite.script('src/index.js', false, { 'defer': true }) }}
		{% else %}
			{{ craft.vite.script('src/index.js') }}
		{% endif %}

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

		<link rel="icon" type="image/png" href="/dist/favicons/favicon-96x96.png" sizes="96x96" />
        <link rel="icon" type="image/svg+xml" href="/dist/favicons/favicon.svg" />
        <link rel="shortcut icon" href="/dist/favicons/favicon.ico" />
        <link rel="apple-touch-icon" sizes="180x180" href="/dist/favicons/apple-touch-icon.png" />
        <link rel="manifest" href="/dist/favicons/site.webmanifest" />
		<meta name="theme-color" content="#112250"/>


		<style>
			[x-cloak] {
				display: none !important
			}
		</style>
	</head>


<body style="margin:0; padding:0; overflow-x:hidden;">

{# ── Content variables ──────────────────────────────────────────────── #}
{% set eyebrow     = entry.lpEyebrow     ?? 'Something extraordinary is coming' %}
{% set headline    = entry.lpHeadline    ?? "Launching\nSoon" %}
{% set body        = entry.lpBody        ?? 'We are putting the finishing touches on something truly special — bespoke private journeys through New Zealand & Australia.' %}
{% set formLabel   = entry.lpFormLabel   ?? 'Be the first to know when we launch' %}
{% set privacyNote = entry.lpPrivacyNote ?? 'No spam. Unsubscribe at any time.' %}
{% set contactEmail = entry.lpContactEmail ?? 'hello@halcyonluxuryjourneys.co.nz' %}
{% set bgImage     = entry.image.one()   ?? null %}
{% set bgVideo     = entry.video.one()   ?? null %}
{% set formEntry   = entry.form.one()    ?? null %}

{# Split headline into two lines for the gold-italic treatment #}
{% set headlineLines = headline|split('\n') %}

<main class="cs-root">

    {# ── Left: cream text panel ──────────────────────────────────────── #}
    <div class="cs-left">

        {# Logo #}
        <a href="/" class="cs-logo-link" aria-label="Halcyon Luxury Journeys — Home">
            <img src="/halcyon-logo.svg" alt="Halcyon Luxury Journeys" class="cs-logo" />
        </a>

        {# Centre text block #}
        <div class="cs-text">

            {% if eyebrow %}
                <p class="cs-eyebrow">{{ eyebrow }}</p>
            {% endif %}

            <h1 class="cs-headline">
                {% if headlineLines|length > 1 %}
                    {{ headlineLines[0] }}<br/>
                    <em>{{ headlineLines[1:] | join('\n') | trim }}</em>
                {% else %}
                    {{ headline }}
                {% endif %}
            </h1>

            <div class="cs-rule" aria-hidden="true"></div>

            {% if body %}
                <p class="cs-body">{{ body }}</p>
            {% endif %}

            {# Newsletter form via Formie #}
            <div class="cs-form-wrap">
                {% if formLabel %}
                    <p class="cs-form-label">{{ formLabel }}</p>
                {% endif %}

                {% if formEntry %}
                    <div class="cs-formie-wrap">
                        {{ craft.formie.renderForm(formEntry) }}
                    </div>
                {% endif %}

                {% if privacyNote %}
                    <p class="cs-privacy">{{ privacyNote }}</p>
                {% endif %}
            </div>

            {# Contact link #}
            {% if contactEmail %}
                <div class="cs-contact">
                    <a href="mailto:{{ contactEmail }}" class="cs-contact-link">{{ contactEmail }}</a>
                </div>
            {% endif %}

        </div>

        {# Footer inside left panel #}
        <div class="cs-footer">
            <span class="cs-footer-text cs-footer-region">New Zealand · Australia</span>
            <span class="cs-footer-text cs-footer-credit">Website by <a href="https://codi.nz" target="_blank" rel="noopener noreferrer" class="cs-footer-credit-link">Codi</a></span>
            <span class="cs-footer-text cs-footer-copy">&copy; {{ now|date('Y') }} Halcyon Luxury Journeys</span>
        </div>

    </div>

    {# ── Right: media panel ──────────────────────────────────────────── #}
    {# Mode: CMS video → video everywhere; CMS image only (no video) → image everywhere; neither → stock image + stock video (mobile img / desktop video) #}
    {% set _stockImg = 'https://images.unsplash.com/photo-1652344433425-e4103642510d?q=80&w=2370&auto=format&fit=crop' %}
    {% set _stockVideo = '/14861093_3840_2160_30fps.mp4' %}
    <div
        class="cs-right cs-right--{% if bgVideo %}video{% elseif bgImage %}image{% else %}fallback{% endif %}"
        aria-hidden="true"
    >
        {% if bgVideo %}
            <video
                id="cs-video"
                autoplay
                muted
                loop
                playsinline
                class="cs-video"
                {% if bgImage %}poster="{{ bgImage.url }}"{% endif %}
            >
                <source src="{{ bgVideo.url }}" type="video/mp4"/>
            </video>
        {% elseif bgImage %}
            <img
                src="{{ bgImage.url }}"
                alt="{{ bgImage.title ?? '' }}"
                class="cs-mobile-photo"
                loading="eager"
                decoding="async"
                width="{{ bgImage.width ?? 900 }}"
                height="{{ bgImage.height ?? 1400 }}"
            />
        {% else %}
            <img
                src="{{ _stockImg }}"
                alt="Queenstown, New Zealand"
                class="cs-mobile-photo"
                loading="eager"
                decoding="async"
                width="900"
                height="1400"
            />
            <video id="cs-video" autoplay muted loop playsinline class="cs-video">
                <source src="{{ _stockVideo }}" type="video/mp4"/>
            </video>
        {% endif %}

    </div>

</main>

<style>
/* ── Root ─────────────────────────────────────────── */
.cs-root {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100dvh;
}

/* ══════════════════════
   LEFT PANEL — cream
══════════════════════ */
.cs-left {
    background: #F5F0E9;
    display: flex;
    flex-direction: column;
    padding: clamp(36px, 4vw, 60px) clamp(36px, 5vw, 72px);
}

/* Logo */
.cs-logo-link { display: block; margin-bottom: clamp(48px, 7vw, 88px); text-decoration: none; }
.cs-logo { width: min(190px, 42vw); height: auto; }

/* Text block */
.cs-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    animation: fadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) both;
}
@keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* Eyebrow */
.cs-eyebrow {
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #C9A96E;
    margin: 0 0 18px;
}

/* Headline */
.cs-headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(48px, 5.5vw, 84px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: #112250;
    margin: 0 0 24px;
}
.cs-headline em {
    font-style: italic;
    color: #C9A96E;
}

/* Rule */
.cs-rule {
    width: 40px;
    height: 1px;
    background: rgba(17, 34, 80, 0.2);
    margin-bottom: 22px;
}

/* Body */
.cs-body {
    font-family: 'Lato', sans-serif;
    font-size: clamp(14px, 1.1vw, 16px);
    font-style: italic;
    line-height: 1.85;
    color: #112250;
    max-width: 400px;
    margin: 0 0 clamp(32px, 4vw, 48px);
}

/* Form wrapper */
.cs-form-wrap { max-width: 440px; margin-bottom: clamp(24px, 3vw, 36px); }
.cs-form-label {
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(17, 34, 80, 0.7);
    margin: 0 0 12px;
}

/* Formie: `src/styles/base/formie.css` (scoped `.cs-formie-wrap`, matches Astro landing form) */

/* Privacy note */
.cs-privacy {
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    color: rgba(17, 34, 80, 0.3);
    margin: 10px 0 0;
    font-style: italic;
    letter-spacing: 0.04em;
}

/* Contact */
.cs-contact { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.cs-contact-link {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    font-style: italic;
    color: #112250;
    text-decoration: none;
    transition: color 0.25s ease;
}
.cs-contact-link:hover { color: #C9A96E; }

/* Footer — one row: region | Website by Codi (centre) | copyright */
.cs-footer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(8px, 2vw, 16px);
    padding-top: clamp(20px, 3vw, 32px);
    margin-top: clamp(28px, 4vw, 48px);
    border-top: 1px solid rgba(17, 34, 80, 0.1);
}
.cs-footer-text {
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: rgba(17, 34, 80, 0.55);
    font-style: italic;
}
.cs-footer-region {
    justify-self: start;
    text-align: left;
}
.cs-footer-credit {
    justify-self: center;
    text-align: center;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: rgba(17, 34, 80, 0.45);
}
.cs-footer-copy {
    justify-self: end;
    text-align: right;
}
.cs-footer-credit-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.25s ease;
}
.cs-footer-credit-link:hover {
    color: #c9a96e;
}

/* ══════════════════════
   RIGHT PANEL — media
   .cs-right--video   = CMS video (full bleed all breakpoints; optional poster if image also set)
   .cs-right--image   = CMS image only (full bleed all breakpoints — desktop + mobile)
   .cs-right--fallback = no CMS assets (stock image mobile, stock video desktop)
══════════════════════ */
.cs-right {
    position: relative;
    overflow: hidden;
}

.cs-right .cs-mobile-photo,
.cs-right .cs-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
}

/* Video from CMS: show at all sizes */
.cs-right--video .cs-video {
    display: block;
}

/* Image from CMS (no video): photo at all sizes */
.cs-right--image .cs-video {
    display: none;
}
.cs-right--image .cs-mobile-photo {
    display: block;
}

/* Fallback: no uploads — mobile photo, desktop video (legacy) */
.cs-right--fallback .cs-video {
    display: none;
}
@media (min-width: 769px) {
    .cs-right--fallback .cs-video {
        display: block;
    }
    .cs-right--fallback .cs-mobile-photo {
        display: none;
    }
}

/* ── Mobile: full-screen background, text overlaid ─── */
@media (max-width: 768px) {
    .cs-root {
        display: block;
        position: relative;
        min-height: 100dvh;
    }

    .cs-right {
        position: fixed;
        inset: 0;
        z-index: 0;
    }
    .cs-right::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(17, 34, 80, 0.45) 0%,
            rgba(17, 34, 80, 0.55) 60%,
            rgba(17, 34, 80, 0.75) 100%
        );
    }

    .cs-left {
        position: relative;
        z-index: 1;
        background: transparent;
        min-height: 100dvh;
    }

    /* Flip text to white on mobile */
    .cs-logo        { filter: brightness(0) invert(1); opacity: 0.9; }
    .cs-eyebrow     { color: #C9A96E; }
    .cs-headline    { color: #ffffff; }
    .cs-headline em { color: #C9A96E; }
    .cs-rule        { background: rgba(255, 255, 255, 0.25); }
    .cs-body        { color: rgba(255, 255, 255, 0.85); }
    .cs-form-label  { color: rgba(255, 255, 255, 0.5); }

    .cs-privacy          { color: rgba(255, 255, 255, 0.3); }
    .cs-contact-link     { color: rgba(255, 255, 255, 0.6); }
    .cs-footer           { border-top-color: rgba(255, 255, 255, 0.1); }
    .cs-footer-text      { color: rgba(255, 255, 255, 0.3); }
    .cs-footer-credit    { color: rgba(255, 255, 255, 0.25); }
}
</style>

<script>
(function() {
    var vid = document.getElementById('cs-video');
    if (vid) {
        vid.loop = true;
        vid.addEventListener('ended', function() { vid.currentTime = 0; vid.play(); });
    }
})();
</script>

{{ endBody() }}

{#
  Formie injects its own CSS via endBody() above.
  These overrides MUST come after that injection to win on source order.
  Scoped to .cs-formie-wrap so they only affect the landing page form.
#}
<style>
/*
 * Formie override — landing page only (.cs-formie-wrap)
 *
 * Actual Formie HTML structure (from DevTools):
 *   .fui-i > form > .fui-form-container > .fui-page
 *     > .fui-page-container > .fui-row.fui-page-row > .fui-field (email)
 *     > .fui-btn-wrapper                        ← sibling of fui-page-container!
 *
 * So .fui-page is the correct flex parent for [field-container] + [btn-wrapper].
 */

/* 1. Strip all default spacing from the form wrapper chain */
.cs-formie-wrap .fui-form,
.cs-formie-wrap .fui-form-container {
  margin: 0 !important;
  padding: 0 !important;
}

/* 2. .fui-page is the real flex parent: holds fui-page-container + fui-btn-wrapper */
.cs-formie-wrap .fui-page {
  display: flex !important;
  flex-direction: row !important;
  flex-wrap: nowrap !important;
  align-items: stretch !important;
  gap: 0 !important;
  margin: 0 !important;
  padding: 0 !important;
}

/* 3. fui-page-container takes all remaining width */
.cs-formie-wrap .fui-page-container {
  flex: 1 1 auto !important;
  min-width: 0 !important;
  margin: 0 !important;
  padding: 0 !important;
  /* remove any flex/grid Formie may add here */
  display: block !important;
}

/* 4. The inner field row — just passthrough, no extra spacing */
.cs-formie-wrap .fui-row,
.cs-formie-wrap .fui-page-row {
  display: block !important;
  margin: 0 !important;
  padding: 0 !important;
  grid-template-columns: unset !important;
  column-gap: 0 !important;
}

.cs-formie-wrap .fui-field {
  margin: 0 !important;
  padding: 0 !important;
}

.cs-formie-wrap .fui-field-container {
  margin: 0 !important;
  padding: 0 !important;
}

.cs-formie-wrap .fui-input-wrapper {
  margin: 0 !important;
  padding: 0 !important;
}

/* Hide the auto-generated field label */
.cs-formie-wrap .fui-label {
  display: none !important;
}

/* 5. Email input */
.cs-formie-wrap .fui-input {
  display: block !important;
  width: 100% !important;
  box-sizing: border-box !important;
  background: #ffffff !important;
  border: 1px solid rgba(17,34,80,0.18) !important;
  border-right: none !important;
  border-radius: 0 !important;
  color: #112250 !important;
  font-family: 'Lato', sans-serif !important;
  font-size: 14px !important;
  font-weight: 300 !important;
  padding: 13px 16px !important;
  outline: none !important;
  box-shadow: none !important;
  -webkit-appearance: none !important;
  appearance: none !important;
}

.cs-formie-wrap .fui-input::placeholder {
  color: rgba(17,34,80,0.3) !important;
}

.cs-formie-wrap .fui-input:focus {
  border-color: #c9a96e !important;
}

/* 6. Submit button wrapper — flush right, no gap */
.cs-formie-wrap .fui-btn-wrapper {
  flex: 0 0 auto !important;
  display: flex !important;
  align-items: stretch !important;
  margin: 0 !important;
  padding: 0 !important;
}

/* 7. Submit button */
.cs-formie-wrap .fui-btn,
.cs-formie-wrap .fui-submit,
.cs-formie-wrap .fui-btn-submit {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-sizing: border-box !important;
  background: #112250 !important;
  border: 1px solid #112250 !important;
  border-radius: 0 !important;
  color: #f5f0e9 !important;
  font-family: 'Lato', sans-serif !important;
  font-size: 11px !important;
  font-weight: 400 !important;
  letter-spacing: 0.16em !important;
  text-transform: uppercase !important;
  padding: 13px 20px !important;
  cursor: pointer !important;
  white-space: nowrap !important;
  box-shadow: none !important;
  margin: 0 !important;
}

.cs-formie-wrap .fui-btn:hover,
.cs-formie-wrap .fui-submit:hover,
.cs-formie-wrap .fui-btn-submit:hover {
  background: #c9a96e !important;
  border-color: #c9a96e !important;
  color: #112250 !important;
}

/* ── Mobile: stack vertically ────────────────────────────────────── */
@media (max-width: 768px) {
  .cs-formie-wrap .fui-page {
    flex-direction: column !important;
  }

  .cs-formie-wrap .fui-btn-wrapper {
    width: 100% !important;
  }

  .cs-formie-wrap .fui-input {
    background: rgba(255,255,255,0.1) !important;
    border: 1px solid rgba(255,255,255,0.3) !important;
    border-bottom: none !important;
    color: #ffffff !important;
  }

  .cs-formie-wrap .fui-input::placeholder {
    color: rgba(255,255,255,0.4) !important;
  }

  .cs-formie-wrap .fui-btn,
  .cs-formie-wrap .fui-submit,
  .cs-formie-wrap .fui-btn-submit {
    width: 100% !important;
    background: #c9a96e !important;
    border-color: #c9a96e !important;
    color: #112250 !important;
  }
}
</style>

</body>
</html>
