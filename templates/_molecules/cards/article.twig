{% set defaults = {
    buttonText: 'Read article',
    tags: self.entry.categories.all,
    date: self.entry.postDate|date('M j, Y'),
    datetime: self.entry.postDate|date('UTC'),
    innerTheme: 'subtle'
} %}

{% set self = self is defined ? defaults|merge(self) : defaults %}

{% embed '_molecules/cards/base' %}
    {% block details %}
        <div class="flex flex-col gap-2 z-1">
            <time class="" datetime="{{ self.datetime|default }}">{{ self.date }}</time>

            {% include '_atoms/tags' with {
                tags: self.tags|map(
                    e => {
                        text: e.title,
                        url: e.url
                    }
                )
            } %}
        </div>

        {{ parent() }}
    {% endblock %}
{% endembed %}
