{% set heading = heading ?? null %}
{% set body = body ?? null %}
{% set links = links ?? null %}

<div class="flex flex-col items-start p-8 bg-gradient-to-br from-grey-800 via-grey-700 to-grey-600 text-white rounded-3xl shadow-xl" data-inner-theme="primary">
    <{{ headingTag }} class="heading-3 mb-4">
        {{ heading }}
    </{{ headingTag }}>

    <div class="copy mb-8">
        {{ body }}
    </div>

    {% include "_molecules/links" with {
        links: links
    } %}
</div>
