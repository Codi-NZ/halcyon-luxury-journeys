{% set heading = heading ?? null %}
{% set body = body ?? null %}
{% set links = links ?? null %}

<div style="background:#112250; padding:clamp(36px,4vw,56px); border:1px solid rgba(245,240,233,0.08);">
    <{{ headingTag }} style="font-family:'Playfair Display',serif; font-size:clamp(22px,2.5vw,32px); font-weight:400; line-height:1.2; color:#F5F0E9; margin-bottom:16px;">
        {{ heading }}
    </{{ headingTag }}>

    {% if body %}
        <div style="font-family:'Lato',sans-serif; font-size:clamp(14px,1.1vw,16px); line-height:1.8; color:rgba(245,240,233,0.6); margin-bottom:32px;">
            {{ body }}
        </div>
    {% endif %}

    {% if links %}
        <ul class="flex flex-wrap" style="gap:16px 24px;">
            {% for link in links %}
                <li>
                    <a
                        href="{{ link.url }}"
                        class="btn-luxury-light"
                        {% if link.newWindow is defined and link.newWindow %}target="_blank" rel="noopener noreferrer"{% endif %}
                    >
                        {{ link.text ?? 'Learn more' }}
                        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                            <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
                        </svg>
                    </a>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
