{% import "macros" as macros %}

{% set heading = heading ?? null %}
{% set id = (id ?? heading|default("accordion-" ~ random(9999)))|kebab ~ "-" ~ (blockIndex ?? random(9999)) %}
{% set body = body ?? null %}
{% set modifiers = modifiers|default ? " " ~ modifiers : null %}
{% set attributes = attributes ?? {} %}

<div class="cb-accordion"
	x-data="{ expanded: false }"
	{{ macros.addAttributes(attributes) }}
>
	<button
		class="cb-accordion-trigger"
		id="{{ id }}-header"
		data-accordion-trigger="true"
		aria-label="Toggle accordion"
		aria-controls="{{ id }}-content"
		:aria-expanded="expanded"
		@click="expanded = !expanded"
	>
		<span class="cb-accordion-title" :style="expanded ? 'color:rgba(17,34,80,0.65)' : ''">{{ heading|raw }}</span>
		<span class="cb-accordion-icon" :class="expanded ? 'is-open' : ''">
			<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
				<line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.2" class="cb-accordion-icon-v"/>
				<line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.2"/>
			</svg>
		</span>
	</button>

	<div class="cb-accordion-panel"
		x-show="expanded"
		id="{{ id }}-content"
		role="region"
		aria-labelledby="{{ id }}-header"
		:aria-hidden="!expanded"
		x-collapse
	>
		<div class="cb-accordion-body">
			{% block main %}
				{{ body|raw }}
			{% endblock %}
		</div>
	</div>
</div>
