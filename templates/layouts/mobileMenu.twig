{% import 'macros' as macros %}
{% import _self as self %}

<div
    class="fixed inset-0 z-50 flex items-stretch justify-end w-full h-full pl-8 transition-all opacity-0 xl:invisible xl:hidden"
    :class="menu ? 'opacity-100! duration-300' : 'pointer-events-none invisible'"
    x-cloak
    @keydown.window.escape="menu = false"
    x-trap.inert.noscroll="menu"
>
    {# Backdrop #}
    <div
        class="absolute inset-0 w-full h-full bg-grey-900/80 backdrop-blur-sm"
        title="Click outside menu to close"
        @click="menu = false; subMenu = false"
    ></div>
    {# Content #}
    <div
        class="relative flex flex-col items-stretch w-full h-full max-w-md gap-6 px-6 overflow-hidden transition-all duration-500 translate-x-full bg-grey-50 text-grey-900 border-l border-grey-200"
        :class="menu ? 'translate-x-0!' : ''"
        data-inner-theme="menu"
    >
        <div class="flex items-center justify-between pt-4">
            <a href="/" class="flex items-center gap-3 text-base font-semibold text-grey-800">
                <span class="inline-flex items-center justify-center rounded-full bg-grey-200 text-grey-700 size-8">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                        class="size-6"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"
                        />
                    </svg>
                </span>
                <span>{{ craft.app.sites.currentSite.name ?? siteName ?? 'Aurora' }}</span>
            </a>

            <button
                type="button"
                aria-label="Close menu"
                @click="menu = false"
                class="rounded-full shrink-0 lg:hidden text-grey-500 hover:text-grey-700 cursor-pointer"
            >
                {{ macros.icon('outline/cross', 'h-6 w-6') }}
            </button>
        </div>

        <label class="relative flex items-center">
            <span class="sr-only">Search</span>
            <input
                type="search"
                name="mobile-global-search"
                placeholder="Search…"
                class="w-full rounded-full border border-grey-200 bg-white px-4 py-2 text-sm text-grey-600 placeholder:text-grey-400 focus:border-grey-400 focus:outline-hidden focus:ring-0"
            />
            <span class="absolute right-3 text-grey-400">{{ macros.icon('outline/search', 'size-4') }}</span>
        </label>

        <div class="relative flex flex-1 w-full overflow-hidden shrink">
            {# Menu #}
            <nav
                aria-label="Main menu"
                class="flex flex-col w-full h-full pt-4 overflow-y-auto transition-all duration-300"
                :class="subMenu ? '-translate-x-full opacity-0' : ''"
            >
                {# Links #}
                <ul class="flex flex-col flex-1 w-full gap-2">
                    {% for parentPage in pages %}
                        {{ self.navLinkMobile(parentPage) }}
                    {% endfor %}
                </ul>
            </nav>
            {% for parentPage in pages|filter(e => e.hasDescendants) %}
                <div
                    class="absolute inset-y-0 z-50 w-full h-full pt-4 overflow-y-auto transition-all duration-300"
                    x-data="{
												uri: '{{ parentPage.uri }}',
												level: {{ parentPage.level }},
											}"
                    x-show="subMenu == uri"
                    x-transition:enter="transition ease-out duration-300"
                    x-transition:enter-start="opacity-0 translate-x-full"
                    x-transition:enter-end="opacity-100 translate-x-0"
                    x-transition:leave="transition ease-in duration-300"
                    x-transition:leave-start="opacity-100 translate-x-0"
                    x-transition:leave-end="opacity-0 translate-x-full"
                >
                    {# Back #}
                    <div class="w-full">
                        <li class="relative flex items-center w-full gap-4 text-left border-b border-grey-200 pb-3">
                            <button
                                class="text-grey-500 hover:text-grey-700 transition-colors"
                                @click="subMenu = '{{ parentPage.parent.uri|default('') }}'"
                            >
                                {{ macros.icon('outline/arrow-left', 'h-5 w-5') }}
                            </button>
                            <a href="{{ parentPage.url }}" class="grow font-medium">{{ parentPage.title }}</a>
                        </li>
                    </div>
                    {# Links #}
                    <ul class="flex flex-col w-full gap-2 mt-4">
                        {% for childPage in parentPage.children %}
                            {{ self.navLinkMobile(childPage) }}
                        {% endfor %}
                    </ul>
                </div>
            {% endfor %}
        </div>

        <a href="{{ siteUrl('contact') }}" class="btn w-full justify-center mb-6">Get in touch</a>
    </div>
</div>

{% macro navLinkMobile(page) %}
    {% import 'macros' as macros %}
    <li
        class="relative flex items-center w-full gap-3 text-left border border-grey-200 rounded-xl px-4 py-3 bg-white shadow-sm"
    >
        <a href="{{ page.url }}" class="flex items-center justify-between grow text-sm font-medium text-grey-700">
            {{ page.title }}
            {% if not page.hasDescendants %}
                {{ macros.icon('outline/chevron-right', 'h-4 w-4 text-grey-400') }}
            {% endif %}
        </a>
        {% if page.hasDescendants %}
            <button
                class="text-grey-400 hover:text-grey-600 transition-colors cursor-pointer"
                @click="subMenu = '{{ page.uri }}'"
            >
                {{ macros.icon('outline/chevron-right', 'h-5 w-5') }}
            </button>
        {% endif %}
    </li>
{% endmacro %}
