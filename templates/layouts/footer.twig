{# Halcyon Luxury Journeys — Site Footer #}

{% set navLinks = [
    { href: '/destinations',       label: 'Destinations' },
    { href: '/signature-journeys', label: 'Signature Journeys' },
    { href: '/inspiration',        label: 'Inspiration' },
    { href: '/about',              label: 'About' },
    { href: '/testimonials',       label: 'Testimonials' },
    { href: '/contact',            label: 'Enquire' },
] %}

<footer style="background:#112250; color:#F5F0E9;">
    <div style="height:1px; background:rgba(245,240,233,0.12);"></div>

    <div class="container-xl section-pad">
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px,1fr)); gap:clamp(40px,5vw,64px); margin-bottom:64px;">

            {# Brand column #}
            <div style="display:flex; flex-direction:column; gap:24px;">
                <img
                    src="/halcyon-logo.svg"
                    alt="Halcyon Luxury Journeys"
                    style="width:min(240px,65vw); height:auto; display:block; filter:brightness(0) saturate(100%) invert(96%) sepia(11%) saturate(295%) hue-rotate(325deg) brightness(104%) contrast(95%);"
                />
                <p class="type-body-font" style="font-size:13px; line-height:1.85; color:rgba(245,240,233,0.6); max-width:280px;">
                    Thoughtfully Crafted Journeys across New Zealand and Australia for the Discerning Traveler.
                </p>
                <div style="width:36px; height:1px; background:rgba(245,240,233,0.25);"></div>
                <p class="type-body-font" style="font-size:11px; font-style:italic; letter-spacing:0.1em; color:rgba(245,240,233,0.4);">
                    New Zealand · Australia
                </p>
            </div>

            {# Navigation column #}
            <div style="display:flex; flex-direction:column; gap:20px;">
                <div class="overline-light" style="margin-bottom:8px;">Navigation</div>
                {% for link in navLinks %}
                    <a href="{{ link.href }}" class="type-body-font"
                       style="font-size:13px; font-style:italic; color:rgba(245,240,233,0.65); letter-spacing:0.08em; text-decoration:none; transition:color 0.3s ease;"
                       onmouseover="this.style.color='#F5F0E9';" onmouseout="this.style.color='rgba(245,240,233,0.65)';">
                        {{ link.label }}
                    </a>
                {% endfor %}
            </div>

            {# Newsletter column #}
            <div style="display:flex; flex-direction:column; gap:20px;">
                <div class="overline-light" style="margin-bottom:8px;">Newsletter</div>
                <p class="type-body-font" style="font-size:13px; font-style:italic; color:rgba(245,240,233,0.5); line-height:1.7;">
                    Stay inspired — sign up for curated travel ideas and Halcyon news.
                </p>
                <form method="post" action="" style="display:flex; flex-direction:column; gap:10px; margin-top:4px;">
                    {{ csrfInput() }}
                    <input
                        type="email"
                        name="email"
                        placeholder="Your email address"
                        required
                        style="background:rgba(245,240,233,0.06); border:1px solid rgba(245,240,233,0.18); color:#F5F0E9; font-family:'Lato',sans-serif; font-size:13px; font-style:italic; padding:11px 14px; outline:none; width:100%;"
                    />
                    <button type="submit"
                            style="background:transparent; border:1px solid rgba(245,240,233,0.3); color:rgba(245,240,233,0.8); font-family:'Lato',sans-serif; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; padding:11px 16px; cursor:pointer; transition:border-color 0.25s ease, color 0.25s ease; text-align:center;"
                            onmouseover="this.style.borderColor='#C9A96E'; this.style.color='#C9A96E';"
                            onmouseout="this.style.borderColor='rgba(245,240,233,0.3)'; this.style.color='rgba(245,240,233,0.8)';">
                        Subscribe
                    </button>
                </form>
            </div>

            {# Contact column #}
            <div style="display:flex; flex-direction:column; gap:20px;">
                <div class="overline-light" style="margin-bottom:8px;">Contact</div>
                <a href="mailto:hello@halcyonluxuryjourneys.co.nz" class="type-body-font"
                   style="font-size:13px; font-style:italic; color:rgba(245,240,233,0.65); text-decoration:none; transition:color 0.3s ease;"
                   onmouseover="this.style.color='#F5F0E9';" onmouseout="this.style.color='rgba(245,240,233,0.65)';">
                    hello@halcyonluxuryjourneys.co.nz
                </a>
                <a href="tel:+64211398539" class="type-body-font"
                   style="font-size:13px; font-style:italic; color:rgba(245,240,233,0.65); text-decoration:none; transition:color 0.3s ease;"
                   onmouseover="this.style.color='#F5F0E9';" onmouseout="this.style.color='rgba(245,240,233,0.65)';">
                    Phone &amp; WhatsApp: +64 21 139 8539
                </a>
                <div style="height:1px; width:36px; background:rgba(245,240,233,0.2); margin-top:4px;"></div>
                <div style="display:flex; align-items:center; gap:24px; margin-top:4px;">
                    <a href="#" class="type-body-font"
                       style="font-size:11px; font-style:italic; letter-spacing:0.15em; color:rgba(245,240,233,0.45); text-decoration:none; transition:color 0.3s ease;"
                       onmouseover="this.style.color='rgba(245,240,233,0.9)';" onmouseout="this.style.color='rgba(245,240,233,0.45)';">Instagram</a>
                    <a href="#" class="type-body-font"
                       style="font-size:11px; font-style:italic; letter-spacing:0.15em; color:rgba(245,240,233,0.45); text-decoration:none; transition:color 0.3s ease;"
                       onmouseover="this.style.color='rgba(245,240,233,0.9)';" onmouseout="this.style.color='rgba(245,240,233,0.45)';">Facebook</a>
                </div>
            </div>

        </div>

        {# Bottom bar #}
        <div style="border-top:1px solid rgba(245,240,233,0.1); padding-top:28px; display:flex; flex-direction:column; gap:8px; align-items:center; text-align:center;">
            <p class="type-body-font" style="font-size:10px; font-style:italic; letter-spacing:0.15em; color:rgba(245,240,233,0.35);">
                &copy; {{ now|date('Y') }} Halcyon Luxury Journeys. All rights reserved.
            </p>
            <p class="type-body-font" style="font-size:10px; font-style:italic; letter-spacing:0.1em; color:rgba(245,240,233,0.2);">
                Thoughtfully Crafted Journeys · Based in Aotearoa New Zealand
            </p>
        </div>
    </div>
</footer>
