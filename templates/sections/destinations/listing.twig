{% extends 'layouts/base' %}

{% block banner %}{% endblock %}

{% block content %}

{# ── Hero area (from Single entry) ──────────────────── #}
{% set eyebrow = entry is defined and entry ? entry.pageEyebrow ?? 'Destinations' : 'Destinations' %}
{% set pageHeading = entry is defined and entry ? entry.heading ?? 'Two Countries.\nInfinite Journeys.' : 'Two Countries.\nInfinite Journeys.' %}
{% set intro = entry is defined and entry ? entry.summary ?? 'New Zealand and Australia — two extraordinary nations, each with its own soul. We know every corner intimately so you don\'t have to.' : 'New Zealand and Australia — two extraordinary nations, each with its own soul. We know every corner intimately so you don\'t have to.' %}

{# ── Data: region cards (NZ first, then Australia) ──── #}
{% set nzRegions = craft.categories.group('nzRegion').all() %}
{% set auRegions = craft.categories.group('australiaRegion').all() %}
{% set regionCards = [] %}
{% for cat in nzRegions %}
    {% set regionCards = regionCards|merge([{ cat: cat, country: 'New Zealand' }]) %}
{% endfor %}
{% for cat in auRegions %}
    {% set regionCards = regionCards|merge([{ cat: cat, country: 'Australia' }]) %}
{% endfor %}

<!-- Page Hero -->
<section class="page-hero">
    <div class="page-hero-inner">
        <p class="eyebrow" data-reveal>{{ eyebrow }}</p>
        <h1 class="page-title" data-reveal data-delay="100">
            {{ pageHeading|nl2br }}
        </h1>
        <p class="page-intro" data-reveal data-delay="200">
            {{ intro }}
        </p>
    </div>
</section>

<!-- Filter Bar + Grid (Alpine component) -->
<div
    x-data="destinationFilters()"
    x-init="init()"
>

    <!-- Filter Bar -->
    <section class="filter-section" aria-label="Filter destinations">
        <div class="filter-inner">
            <div class="filter-controls">

                <!-- Country -->
                <div class="filter-group">
                    <span class="filter-group-label" id="country-filter-label">Country</span>
                    <div class="filter-pills" role="group" aria-labelledby="country-filter-label">
                        <button
                            class="filter-pill"
                            :class="{ 'is-active': country === 'all' }"
                            :aria-pressed="(country === 'all').toString()"
                            @click="setCountry('all')"
                        >All Countries</button>
                        <button
                            class="filter-pill"
                            :class="{ 'is-active': country === 'New Zealand' }"
                            :aria-pressed="(country === 'New Zealand').toString()"
                            @click="setCountry('New Zealand')"
                        >New Zealand</button>
                        <button
                            class="filter-pill"
                            :class="{ 'is-active': country === 'Australia' }"
                            :aria-pressed="(country === 'Australia').toString()"
                            @click="setCountry('Australia')"
                        >Australia</button>
                    </div>
                </div>

                <div class="filter-divider" aria-hidden="true"></div>

                <!-- Region (dynamic, scoped by country) -->
                <div class="filter-group">
                    <span class="filter-group-label" id="region-filter-label">Region</span>
                    <div class="filter-pills" role="group" aria-labelledby="region-filter-label">
                        <button
                            class="filter-pill"
                            :class="{ 'is-active': region === 'all' }"
                            :aria-pressed="(region === 'all').toString()"
                            @click="setRegion('all', null)"
                        >All Regions</button>
                        {% for cat in nzRegions %}
                            <button
                                class="filter-pill"
                                x-show="country === 'all' || country === 'New Zealand'"
                                :class="{ 'is-active': region === '{{ cat.slug }}' }"
                                :aria-pressed="(region === '{{ cat.slug }}').toString()"
                                @click="setRegion('{{ cat.slug }}', 'New Zealand')"
                            >{{ cat.title }}</button>
                        {% endfor %}
                        {% for cat in auRegions %}
                            <button
                                class="filter-pill"
                                x-show="country === 'all' || country === 'Australia'"
                                :class="{ 'is-active': region === '{{ cat.slug }}' }"
                                :aria-pressed="(region === '{{ cat.slug }}').toString()"
                                @click="setRegion('{{ cat.slug }}', 'Australia')"
                            >{{ cat.title }}</button>
                        {% endfor %}
                    </div>
                </div>

            </div>
            <p class="filter-count" aria-live="polite" aria-atomic="true">
                <span x-text="visibleCount" style="font-family:'Playfair Display',serif; font-size:18px; font-style:normal; color:#112250; line-height:1;"></span>
                <span class="filter-count-label">regions</span>
            </p>
        </div>
    </section>

    <!-- Regions Grid -->
    <section class="dest-section">
        <div class="dest-inner">
            <div class="dest-grid" id="dest-grid">
                {% for card in regionCards %}
                    {% set cat = card.cat %}
                    {% set country = card.country %}
                    {% set image = cat.image.one() ?? null %}
                    {% set excerpt = cat.excerpt ?? '' %}

                    <a
                        href="{{ cat.url }}"
                        class="dest-item"
                        data-country="{{ country }}"
                        data-region="{{ cat.slug }}"
                        x-show="matchCard('{{ country }}', '{{ cat.slug }}')"
                        x-transition:enter="transition ease-out duration-300"
                        x-transition:enter-start="opacity-0 translate-y-4"
                        x-transition:enter-end="opacity-100 translate-y-0"
                    >
                        <div class="dest-img-wrap">
                            {% if image %}
                                {% set imgUrl = image.getUrl('cardMedium') ?? image.url %}
                                {% if imgUrl %}
                                    <img
                                        src="{{ imgUrl }}"
                                        alt="{{ image.alt ?? image.title ?? cat.title }}"
                                        class="dest-img"
                                        loading="lazy"
                                        decoding="async"
                                        width="{{ image.getWidth('cardMedium') ?? image.width ?? 700 }}"
                                        height="{{ image.getHeight('cardMedium') ?? image.height ?? 440 }}"
                                    />
                                {% endif %}
                            {% endif %}
                        </div>
                        <div class="dest-info">
                            <div class="dest-meta-row">
                                <span class="dest-country-tag">{{ country }}</span>
                            </div>
                            <h3 class="dest-name">{{ cat.title }}</h3>
                            {% if excerpt %}
                                <p class="dest-desc">{{ excerpt }}</p>
                            {% endif %}
                            <span class="dest-card-cta btn-luxury">
                                Explore {{ cat.title }}
                                <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                                    <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
                                </svg>
                            </span>
                        </div>
                    </a>
                {% endfor %}
            </div>

            <!-- Empty state -->
            <div class="dest-empty" x-show="visibleCount === 0" x-cloak>
                <div class="rule" style="margin: 0 auto 28px;"></div>
                <p class="dest-empty-msg">No regions match your current filters.</p>
                <button class="dest-reset-btn btn-luxury" @click="resetFilters()">
                    Clear all filters
                    <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                        <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
                    </svg>
                </button>
            </div>
        </div>
    </section>

</div>

<!-- Begin Planning CTA -->
<section class="plan-cta" data-reveal>
    <div class="plan-cta-inner">
        <div class="rule" style="margin-bottom: 32px;"></div>
        <p class="plan-cta-eyebrow">Ready to explore?</p>
        <h2 class="plan-cta-heading">Every journey begins with a conversation.</h2>
        <p class="plan-cta-body">
            Tell us where you'd like to go — and we'll take care of everything else.
        </p>
        <a href="/contact" class="btn-filled btn-filled-light">
            Begin an Enquiry
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
            </svg>
        </a>
    </div>
</section>

<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('destinationFilters', () => ({
        country: 'all',
        region: 'all',
        cards: {{ regionCards|map(c => { slug: c.cat.slug, country: c.country })|json_encode|raw }},
        nzRegionSlugs: {{ nzRegions|map(c => c.slug)|json_encode|raw }},
        auRegionSlugs: {{ auRegions|map(c => c.slug)|json_encode|raw }},

        get visibleCount() {
            return this.cards.filter(c => this.matchCard(c.country, c.slug)).length;
        },

        init() {
            const params = new URLSearchParams(window.location.search);
            this.country = params.get('country') || 'all';
            this.region = params.get('region') || 'all';

            if (this.region !== 'all') {
                const derived = this.countryForRegion(this.region);
                if (derived && this.country !== derived) {
                    this.country = derived;
                }
            }
        },

        countryForRegion(slug) {
            if (this.nzRegionSlugs.includes(slug)) return 'New Zealand';
            if (this.auRegionSlugs.includes(slug)) return 'Australia';
            return null;
        },

        setCountry(value) {
            this.country = value;
            if (this.region !== 'all') {
                const regionCountry = this.countryForRegion(this.region);
                if (value !== 'all' && regionCountry !== value) {
                    this.region = 'all';
                }
            }
            this.syncUrl();
        },

        setRegion(value, parentCountry) {
            this.region = value;
            if (parentCountry) {
                this.country = parentCountry;
            }
            this.syncUrl();
        },

        resetFilters() {
            this.country = 'all';
            this.region = 'all';
            this.syncUrl();
        },

        matchCard(cardCountry, cardRegion) {
            const countryMatch = this.country === 'all' || cardCountry === this.country;
            const regionMatch = this.region === 'all' || cardRegion === this.region;
            return countryMatch && regionMatch;
        },

        syncUrl() {
            const params = new URLSearchParams();
            if (this.country !== 'all') params.set('country', this.country);
            if (this.region !== 'all') params.set('region', this.region);
            const qs = params.toString();
            const url = window.location.pathname + (qs ? '?' + qs : '');
            window.history.replaceState({}, '', url);
        }
    }));
});
</script>

{% endblock %}
