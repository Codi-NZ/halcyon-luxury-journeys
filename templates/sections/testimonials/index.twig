{% extends 'layouts/base' %}

{% block banner %}{% endblock %}

{% block content %}

{% set allTestimonials = craft.entries()
    .section('testimonials')
    .orderBy('dateCreated desc')
    .all()
%}

{# ── Page Hero ── #}
<section class="page-hero">
    <div class="page-hero-inner">
        {% if entry.pageEyebrow ?? null %}
            <p class="eyebrow" data-reveal>{{ entry.pageEyebrow }}</p>
        {% endif %}
        <{{ headingTag1 }} class="page-title" data-reveal data-delay="100">{{ entry.title }}</{{ headingTag1 }}>
        {% if entry.summary ?? null %}
            <p class="page-intro" data-reveal data-delay="200">
                {{ entry.summary }}
            </p>
        {% endif %}
    </div>
</section>

{# ── Testimonials Grid ── #}
<section class="section-pad bg-cream" style="position:relative; overflow:hidden;">

    {# Decorative quote mark #}
    <div
        class="quote-mark"
        style="position:absolute; top:40px; left:50%; transform:translateX(-50%); pointer-events:none; user-select:none;"
        aria-hidden="true"
    >&ldquo;</div>

    <div class="container-lg">

        {% if allTestimonials|length %}
            <div class="testimonials-grid">
                {% for testimonial in allTestimonials %}
                    <div
                        class="testimonial-card"
                        data-reveal
                        data-delay="{{ loop.index0 * 100 }}"
                    >
                        <div class="testimonial-card-rule"></div>

                        <blockquote class="testimonial-card-quote">
                            &ldquo;{{ testimonial.testimonialQuote }}&rdquo;
                        </blockquote>

                        <div class="testimonial-card-author">
                            <div class="testimonial-card-name">{{ testimonial.title }}</div>
                            {% if testimonial.testimonialOrigin %}
                                <div class="testimonial-card-origin">{{ testimonial.testimonialOrigin }}</div>
                            {% endif %}
                            {% if testimonial.testimonialJourney %}
                                <div class="testimonial-card-journey">{{ testimonial.testimonialJourney }}</div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div style="text-align:center; padding:clamp(60px,8vw,100px) 0;">
                <p class="type-heading-font" style="font-size:clamp(18px,1.6vw,24px); font-style:italic; color:rgba(17,34,80,0.5);">
                    No testimonials yet.
                </p>
            </div>
        {% endif %}

    </div>
</section>

{# ── CTA ── #}
<section class="plan-cta" data-reveal>
    <div class="plan-cta-inner">
        <div class="rule" style="margin-bottom:32px; background:rgba(201,169,110,0.4);"></div>
        <p class="plan-cta-eyebrow">Your story starts here</p>
        <h2 class="plan-cta-heading">Ready to create your own story?</h2>
        <p class="plan-cta-body">
            Tell us what inspires you — and we'll craft a bespoke journey around it.
        </p>
        <a href="/contact" class="btn-filled-light">
            Begin Your Journey
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
            </svg>
        </a>
    </div>
</section>

{% endblock %}
