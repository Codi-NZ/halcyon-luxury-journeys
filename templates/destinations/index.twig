{% extends 'layouts/base' %}

{% block banner %}{% endblock %}

{% block content %}

{# ── Hero area (from Single entry) ──────────────────── #}
{% set eyebrow = entry is defined and entry ? entry.pageEyebrow ?? 'Destinations' : 'Destinations' %}
{% set pageHeading = entry is defined and entry ? entry.heading ?? 'Two Countries.\nInfinite Journeys.' : 'Two Countries.\nInfinite Journeys.' %}
{% set intro = entry is defined and entry ? entry.summary ?? 'New Zealand and Australia — two extraordinary nations, each with its own soul. We know every corner intimately so you don\'t have to.' : 'New Zealand and Australia — two extraordinary nations, each with its own soul. We know every corner intimately so you don\'t have to.' %}

{# ── Data ───────────────────────────────────────────── #}
{% set items = craft.entries.section('destinations').all() %}
{% set typeCategories = craft.categories.group('destinationType').all() %}

<!-- Page Hero -->
<section class="page-hero">
    <div class="page-hero-inner">
        <p class="eyebrow" data-reveal>{{ eyebrow }}</p>
        <h1 class="page-title" data-reveal data-delay="100">
            {{ pageHeading|nl2br }}
        </h1>
        <p class="page-intro" data-reveal data-delay="200">
            {{ intro }}
        </p>
    </div>
</section>

<!-- Filter Bar + Grid (Alpine component) -->
<div
    x-data="destinationFilters()"
    x-init="init()"
>

    <!-- Filter Bar -->
    <section class="filter-section" aria-label="Filter destinations">
        <div class="filter-inner">
            <div class="filter-controls">

                <!-- Country -->
                <div class="filter-group">
                    <span class="filter-group-label" id="country-filter-label">Country</span>
                    <div class="filter-pills" role="group" aria-labelledby="country-filter-label">
                        <button
                            class="filter-pill"
                            :class="{ 'is-active': country === 'all' }"
                            :aria-pressed="(country === 'all').toString()"
                            @click="setCountry('all')"
                        >All Countries</button>
                        <button
                            class="filter-pill"
                            :class="{ 'is-active': country === 'New Zealand' }"
                            :aria-pressed="(country === 'New Zealand').toString()"
                            @click="setCountry('New Zealand')"
                        >New Zealand</button>
                        <button
                            class="filter-pill"
                            :class="{ 'is-active': country === 'Australia' }"
                            :aria-pressed="(country === 'Australia').toString()"
                            @click="setCountry('Australia')"
                        >Australia</button>
                    </div>
                </div>

                <div class="filter-divider" aria-hidden="true"></div>

                <!-- Type (dynamic from categories) -->
                <div class="filter-group">
                    <span class="filter-group-label" id="type-filter-label">Type</span>
                    <div class="filter-pills" role="group" aria-labelledby="type-filter-label">
                        <button
                            class="filter-pill"
                            :class="{ 'is-active': type === 'all' }"
                            :aria-pressed="(type === 'all').toString()"
                            @click="setType('all')"
                        >All Types</button>
                        {% for cat in typeCategories %}
                            <button
                                class="filter-pill"
                                :class="{ 'is-active': type === '{{ cat.slug }}' }"
                                :aria-pressed="(type === '{{ cat.slug }}').toString()"
                                @click="setType('{{ cat.slug }}')"
                            >{{ cat.title }}</button>
                        {% endfor %}
                    </div>
                </div>

            </div>
            <p class="filter-count" aria-live="polite" aria-atomic="true">
                <span x-text="visibleCount" style="font-family:'Playfair Display',serif; font-size:18px; font-style:normal; color:#112250; line-height:1;"></span>
                <span class="filter-count-label">destinations</span>
            </p>
        </div>
    </section>

    <!-- Destinations Grid -->
    <section class="dest-section">
        <div class="dest-inner">
            <div class="dest-grid" id="dest-grid">
                {% for item in items %}
                    {% set image = item.destinationImage.one() ?? null %}
                    {% set country = item.destinationCountry.label ?? '' %}
                    {% set countrySlug = item.destinationCountry.value ?? '' %}
                    {% set types = item.destinationType.all() ?? [] %}

                    <a
                        href="{{ item.url }}"
                        class="dest-item"
                        data-country="{{ country }}"
                        data-types="{{ types|map(t => t.slug)|join(',') }}"
                        x-show="matchItem('{{ country }}', '{{ types|map(t => t.slug)|join(',') }}')"
                        x-transition:enter="transition ease-out duration-300"
                        x-transition:enter-start="opacity-0 translate-y-4"
                        x-transition:enter-end="opacity-100 translate-y-0"
                    >
                        <div class="dest-img-wrap">
                            {% if image %}
                                {% set transformed = image.setTransform('cardMedium') %}
                                <img
                                    src="{{ transformed.url }}"
                                    alt="{{ image.alt ?? image.title ?? item.title }}"
                                    class="dest-img"
                                    loading="lazy"
                                    decoding="async"
                                    width="{{ transformed.width }}"
                                    height="{{ transformed.height }}"
                                />
                            {% endif %}
                            {% if types|length %}
                                {% set badgeColors = ['#112250', '#C9A96E', '#2C4A7C', '#8B6914', '#4A5568', '#2D6A4F'] %}
                                <div class="dest-badges">
                                    {% for type in types %}
                                        {% set badgeLabel = attribute(type, 'categoryTag') ?? type.title %}
                                        <span
                                            class="dest-badge"
                                            style="background: {{ badgeColors[loop.index0 % badgeColors|length] }}; color: #F5F0E9;"
                                        >{{ badgeLabel }}</span>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                        <div class="dest-info">
                            <div class="dest-meta-row">
                                <span class="dest-country-tag">{{ country }}</span>
                                {% if item.destinationLocation %}
                                    <span class="dest-sep" aria-hidden="true">&middot;</span>
                                    <span class="dest-location">{{ item.destinationLocation }}</span>
                                {% endif %}
                            </div>
                            <h3 class="dest-name">{{ item.title }}</h3>
                            {% if item.destinationDescription %}
                                <p class="dest-desc">{{ item.destinationDescription }}</p>
                            {% endif %}
                            <span class="dest-card-cta btn-luxury">
                                View More
                                <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                                    <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
                                </svg>
                            </span>
                        </div>
                    </a>
                {% endfor %}
            </div>

            <!-- Empty state -->
            <div class="dest-empty" x-show="visibleCount === 0" x-cloak>
                <div class="rule" style="margin: 0 auto 28px;"></div>
                <p class="dest-empty-msg">No destinations match your current filters.</p>
                <button class="dest-reset-btn btn-luxury" @click="resetFilters()">
                    Clear all filters
                    <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                        <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1.2"/>
                    </svg>
                </button>
            </div>
        </div>
    </section>

</div>

<!-- Begin Planning CTA -->
<section class="plan-cta" data-reveal>
    <div class="plan-cta-inner">
        <div class="rule" style="margin-bottom: 32px;"></div>
        <p class="plan-cta-eyebrow">Ready to explore?</p>
        <h2 class="plan-cta-heading">Every journey begins with a conversation.</h2>
        <p class="plan-cta-body">
            Tell us where you'd like to go — and we'll take care of everything else.
        </p>
        <a href="/contact" class="btn-filled btn-filled-light">
            Begin an Enquiry
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
            </svg>
        </a>
    </div>
</section>

<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('destinationFilters', () => ({
        country: 'all',
        type: 'all',
        totalItems: 0,
        visibleCount: 0,

        init() {
            // Read filters from URL on load
            const params = new URLSearchParams(window.location.search);
            this.country = params.get('country') || 'all';
            this.type = params.get('type') || 'all';

            this.$nextTick(() => { this.updateCount(); });
        },

        setCountry(value) {
            this.country = value;
            this.syncUrl();
            this.$nextTick(() => { this.updateCount(); });
        },

        setType(value) {
            this.type = value;
            this.syncUrl();
            this.$nextTick(() => { this.updateCount(); });
        },

        resetFilters() {
            this.country = 'all';
            this.type = 'all';
            this.syncUrl();
            this.$nextTick(() => { this.updateCount(); });
        },

        matchItem(itemCountry, itemTypes) {
            const countryMatch = this.country === 'all' || itemCountry === this.country;
            const typeSlugs = itemTypes ? itemTypes.split(',') : [];
            const typeMatch = this.type === 'all' || typeSlugs.includes(this.type);
            return countryMatch && typeMatch;
        },

        updateCount() {
            const items = this.$el.querySelectorAll('.dest-item');
            let count = 0;
            items.forEach(item => {
                const itemCountry = item.dataset.country || '';
                const itemTypes = item.dataset.types || '';
                if (this.matchItem(itemCountry, itemTypes)) count++;
            });
            this.visibleCount = count;
        },

        syncUrl() {
            const params = new URLSearchParams();
            if (this.country !== 'all') params.set('country', this.country);
            if (this.type !== 'all') params.set('type', this.type);
            const qs = params.toString();
            const url = window.location.pathname + (qs ? '?' + qs : '');
            window.history.replaceState({}, '', url);
        }
    }));
});
</script>

{% endblock %}
