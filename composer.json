{
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "carlcs/craft-uielementfields": "3.0.0",
    "craftcms/aws-s3": "^2.3.0",
    "craftcms/ckeditor": "^5.4.0",
    "craftcms/cms": "^5.9.20",
    "craftcms/feed-me": "6.11.0",
    "doublesecretagency/craft-cpcss": "3.0.0",
    "ether/simplemap": "5.0.4",
    "nystudio107/craft-seomatic": "^5.1.21",
    "nystudio107/craft-vite": "5.0.1",
    "putyourlightson/craft-blitz": "5.10.2",
    "putyourlightson/craft-elements-panel": "^3.0.1",
    "spicyweb/craft-embedded-assets": "^5.4.7",
    "superbig/craft-mjml": "^5.0.2",
    "topshelfcraft/environment-label": "5.0.0",
    "verbb/buttonbox": "5.0.0",
    "verbb/field-manager": "4.0.3",
    "verbb/formie": "^3.1.21",
    "verbb/hyper": "^2.3.5",
    "verbb/knock-knock": "3.0.5",
    "verbb/tablemaker": "^5.0.8",
    "vlucas/phpdotenv": "^5.4.0"
  },
  "require-dev": {
    "craftcms/generator": "^2.0.0",
    "yiisoft/yii2-shell": "^2.0.3"
  },
  "autoload": {
    "psr-4": {
      "simple\\simplemodule\\": "modules/simpleModule/"
    }
  },
  "config": {
    "allow-plugins": {
      "craftcms/plugin-installer": true,
      "yiisoft/yii2-composer": true
    },
    "sort-packages": true,
    "optimize-autoloader": true,
    "platform": {
      "php": "8.2"
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example.dev', '.env');\""
    ]
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://composer.craftcms.com",
      "canonical": false
    }
  ]
}
