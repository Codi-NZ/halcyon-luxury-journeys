<!-- Full-bleed CTA — cinematic image with overlay -->
<section style="position:relative; min-height:560px; display:flex; align-items:center; justify-content:center; overflow:hidden;">

  <!-- Background image -->
  <img
    src="https://picsum.photos/seed/nz-lake-reflection/2400/1200"
    alt="Lake Matheson reflection, New Zealand"
    style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;"
    loading="lazy"
    decoding="async"
  />

  <!-- Overlay -->
  <div
    style="position:absolute; inset:0; background:linear-gradient(135deg, rgba(17,34,80,0.78) 0%, rgba(17,34,80,0.55) 100%);"
  ></div>

  <!-- Content -->
  <div
    class="container-lg"
    style="position:relative; z-index:1; display:flex; flex-direction:column; align-items:center; text-align:center; padding-top:80px; padding-bottom:80px;"
  >
    <div class="overline-light mb-8" data-reveal>work with us</div>

    <h2
      class="display"
      style="font-size:clamp(48px,7vw,96px); color:#F5F0E9; line-height:1; margin-bottom:24px; max-width:800px;"
      data-reveal
      data-delay="100"
    >
      Partner<br />
      <em style="font-style:italic; color:#C9A96E;">With Us</em>
    </h2>

    <p
      class="type-body-font"
      style="font-size:clamp(14px,1.5vw,17px); font-style:italic; color:rgba(245,240,233,0.75); line-height:1.9; max-width:600px; margin-bottom:48px;"
      data-reveal
      data-delay="200"
    >
      We love partnering with travel professionals who share our passion for exceptional journeys, and we're proud to be your trusted experts in New Zealand and Australia. When you work with us, you gain a dedicated on‑the‑ground team delivering standout experiences through deep local insight, strong relationships, and seamless operational support. Together, we create journeys that truly shine — the kind your clients remember and the kind that make you look like a rockstar.
    </p>

    <div class="flex flex-col sm:flex-row items-center gap-5" data-reveal data-delay="300">
      <a href="/contact" class="btn-filled btn-filled-light">
        Begin an Enquiry
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
          <path d="M9 1l4 4-4 4M13 5H1" stroke="currentColor" stroke-width="1"/>
        </svg>
      </a>
    </div>
  </div>
</section>
