---
const destinations = [
  {
    name: 'New Zealand',
    region: 'Aotearoa',
    image: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=1400&q=85',
    description: 'From the ancient rainforests of Fiordland to the geothermal wonders of Rotorua, the golden vineyards of Marlborough to the remote beaches of the Coromandel — New Zealand is a land of breathtaking contrast. We know every corner intimately, and we bring it to life for those who travel with intention.',
    categories: [
      { label: 'Exceptional Places to Stay', href: '/destinations/new-zealand/places-to-stay' },
      { label: 'Exceptional Experiences',    href: '/destinations/new-zealand/experiences' },
    ],
  },
  {
    name: 'Australia',
    region: 'The Great South Land',
    image: 'https://images.unsplash.com/photo-1523482580672-f109ba8cb9be?auto=format&fit=crop&w=1400&q=85',
    description: 'From the rust-red silence of Uluru to the turquoise waters of the Whitsundays, the ancient cultures of the Kimberley to the world-class dining of Melbourne — Australia rewards those who go beyond the obvious. We curate access to its most extraordinary places, experiences, and people.',
    categories: [
      { label: 'Exceptional Places to Stay', href: '/destinations/australia/places-to-stay' },
      { label: 'Exceptional Experiences',    href: '/destinations/australia/experiences' },
    ],
  },
];
---

<section class="section-pad" style="background:#ffffff;">
  <div class="container-xl">

    <!-- Header -->
    <div
      style="
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:clamp(40px,6vw,120px);
        align-items:start;
        padding-bottom:clamp(56px,7vw,96px);
        border-bottom:1px solid rgba(17,34,80,0.12);
      "
    >
      <div>
        <div class="overline mb-4" data-reveal>our destinations</div>
        <h2
          class="display text-navy"
          style="font-size:clamp(32px,3.5vw,52px); line-height:1.05; letter-spacing:0.02em;"
          data-reveal
          data-delay="100"
        >
          Two Countries.<br/>Infinite Journeys.
        </h2>
      </div>

      <div data-reveal="right" data-delay="150">
        <p
          class="type-body-font"
          style="font-size:clamp(15px,1.1vw,18px); line-height:1.8; color:rgba(17,34,80,0.68);"
        >
          We operate exclusively across New Zealand and parts of Australia, drawing on deep regional expertise and strong local partnerships to deliver seamless, high‑quality experiences. These two extraordinary countries are more than destinations to us — they're the places where we live, work, and create — and showcase with pride.
        </p>
      </div>
    </div>

    <!-- Two accordion rows -->
    <div>
      {destinations.map(({ name, region, image, description, categories }, i) => (
        <div class="accordion-item" data-reveal data-delay={String(i * 80)}>

          <button
            class="accordion-trigger"
            aria-expanded="false"
            aria-controls={`dest-panel-${i}`}
            id={`dest-trigger-${i}`}
          >
            <span class="accordion-num type-body-font">0{i + 1}</span>
            <span class="accordion-name type-heading-font">{name}</span>
            <span class="accordion-sub type-body-font">{region}</span>
            <span class="accordion-icon" aria-hidden="true">+</span>
          </button>

          <div
            class="accordion-panel"
            id={`dest-panel-${i}`}
            role="region"
            aria-labelledby={`dest-trigger-${i}`}
          >
            <div class="accordion-panel-inner">
              <div class="accordion-panel-grid">
                <div class="accordion-img-wrap">
                  <img
                    src={image}
                    alt={name}
                    class="accordion-img"
                    loading="lazy"
                    decoding="async"
                    width="700"
                    height="400"
                  />
                </div>
                <div class="accordion-content">
                  <p class="accordion-description">{description}</p>
                  <div class="accordion-categories">
                    {categories.map(({ label, href }) => (
                      <a href={href} class="accordion-category-btn">
                        {label}
                        <span aria-hidden="true">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      ))}
      <div style="border-top:1px solid rgba(17,34,80,0.12);"></div>
    </div>

  </div>
</section>

<style>
  .accordion-item {
    border-top: 1px solid rgba(17,34,80,0.12);
  }
  .accordion-item:first-child {
    border-top: none;
  }

  .accordion-trigger {
    width: 100%;
    display: grid;
    grid-template-columns: clamp(36px,3vw,56px) 1fr auto auto;
    align-items: center;
    gap: clamp(16px,3vw,48px);
    padding: clamp(24px,2.8vw,40px) 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  .accordion-num {
    font-size: clamp(10px,0.7vw,12px);
    letter-spacing: 0.2em;
    color: rgba(17,34,80,0.3);
    font-style: italic;
  }

  .accordion-name {
    font-size: clamp(32px,4.5vw,68px);
    font-weight: 400;
    letter-spacing: 0.03em;
    color: #112250;
    line-height: 1;
    transition: opacity 0.2s ease;
  }

  .accordion-trigger:hover .accordion-name {
    opacity: 0.65;
  }

  .accordion-sub {
    font-size: clamp(11px,0.75vw,13px);
    font-style: italic;
    letter-spacing: 0.12em;
    color: rgba(17,34,80,0.4);
    white-space: nowrap;
  }

  .accordion-icon {
    width: clamp(36px,2.8vw,48px);
    height: clamp(36px,2.8vw,48px);
    border: 1px solid rgba(17,34,80,0.25);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: rgba(17,34,80,0.5);
    font-size: 22px;
    font-weight: 300;
    font-family: 'Lato', sans-serif;
    transition: all 0.25s ease;
    line-height: 1;
  }

  .accordion-trigger[aria-expanded="true"] .accordion-icon {
    background: #112250;
    border-color: #112250;
    color: #F5F0E9;
  }

  /* Panel animation */
  .accordion-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .accordion-panel.is-open {
    grid-template-rows: 1fr;
  }

  .accordion-panel-inner {
    overflow: hidden;
  }

  .accordion-panel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px,5vw,80px);
    padding-bottom: clamp(36px,4vw,64px);
    align-items: center;
  }

  .accordion-img-wrap {
    overflow: hidden;
    aspect-ratio: 16/10;
  }

  .accordion-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .accordion-img-wrap:hover .accordion-img {
    transform: scale(1.04);
  }

  .accordion-description {
    font-family: 'Lato', sans-serif;
    font-size: clamp(14px, 1vw, 16px);
    font-style: italic;
    line-height: 1.85;
    color: rgba(17,34,80,0.65);
    margin-bottom: clamp(24px, 2.5vw, 36px);
    max-width: 480px;
  }

  .accordion-categories {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .accordion-category-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid rgba(17,34,80,0.35);
    padding-bottom: 2px;
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(17,34,80,0.85);
    text-decoration: none;
    width: fit-content;
    transition: gap 0.3s ease, border-color 0.3s ease, color 0.3s ease;
  }
  .accordion-category-btn:hover {
    gap: 14px;
    border-color: rgba(17,34,80,0.85);
    color: #112250;
  }

  @media (max-width: 640px) {
    .accordion-trigger {
      grid-template-columns: clamp(28px,3vw,40px) 1fr auto;
    }
    .accordion-sub { display: none; }
    .accordion-panel-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll<HTMLButtonElement>('.accordion-trigger');

    triggers.forEach((trigger) => {
      const icon = trigger.querySelector('.accordion-icon');
      if (icon) icon.textContent = '+';

      trigger.addEventListener('click', () => {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        const panel = document.getElementById(trigger.getAttribute('aria-controls')!)!;

        // Close all others
        triggers.forEach((t) => {
          if (t !== trigger) {
            t.setAttribute('aria-expanded', 'false');
            document.getElementById(t.getAttribute('aria-controls')!)!.classList.remove('is-open');
            const ic = t.querySelector('.accordion-icon');
            if (ic) ic.textContent = '+';
          }
        });

        const next = !isOpen;
        trigger.setAttribute('aria-expanded', String(next));
        panel.classList.toggle('is-open', next);
        if (icon) icon.textContent = next ? '−' : '+';
      });
    });
  });
</script>
